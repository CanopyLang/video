module Video.Config exposing
    ( Config
    , Theme(..)
    , ThemeVars
    , AspectRatio(..)
    , CaptionFontSize(..)
    , CaptionStyle
    , ExternalCaptionTrack
    , defaultConfig
    )


{-| Player configuration for `canopy/video`.

All player behaviour is controlled through a `Config` record passed
to `Video.init`, `Video.update`, and `Video.view`. Keeping Config
separate from State allows the parent to change configuration without
rebuilding the player.

# Configuration
@docs Config, defaultConfig

# Theme
@docs Theme, ThemeVars

# Aspect Ratio
@docs AspectRatio

# Caption Style
@docs CaptionFontSize, CaptionStyle

# External Tracks
@docs ExternalCaptionTrack

-}


import Media
import Video.Source exposing (Source)



-- CONFIG


{-| Complete player configuration.

  - `source` — the primary video source (plain URL, HLS, or DASH).
  - `sources` — additional `Plain` sources tried as codec fallbacks when
    `source` is a `Plain` source and this list is non-empty. The browser
    renders each entry as a `<source>` element and selects the first codec
    it can decode. HLS and DASH sources in this list are ignored.
  - `mediaId` — the DOM element ID used to find the `<video>` element.
  - `autoplay` — start playing when the player is ready (requires muted
    or a prior user gesture; browsers block unmuted autoplay).
  - `muted` — start with audio muted.
  - `loop` — restart from the beginning when playback ends.
  - `poster` — URL of a poster image shown before playback starts.
  - `preload` — browser preload hint.
  - `theme` — colour theme for the controls.
  - `aspectRatio` — maintain a fixed aspect ratio container.
  - `showControls` — whether to show the built-in control bar.
  - `keyboardShortcuts` — enable Space/arrows/etc. keyboard shortcuts.
  - `showKeyboardHelp` — show a `?` button and help overlay listing all
    keyboard shortcuts. Only meaningful when `keyboardShortcuts` is True.
  - `thumbnailVttUrl` — optional URL of a WebVTT sprite sheet for seek
    thumbnails. When Nothing, live frame capture via
    `Media.Capture.captureFrameAt` is used instead.
  - `enableTouchGestures` — enable tap/swipe touch gestures (default True).
  - `captionStyle` — font size and background opacity for caption cue boxes.
  - `externalCaptionTracks` — subtitle and caption files to inject as
    `<track>` elements. Tracks injected this way are automatically discovered
    by the player after the media element loads.

Player events (ready, error, ended) are communicated to the parent
application via `Video.OutMsg` returned from `Video.update`.

-}
type alias Config =
    { source : Source
    , sources : List Source
    , mediaId : Media.MediaId
    , autoplay : Bool
    , muted : Bool
    , loop : Bool
    , poster : Maybe String
    , preload : Media.Preload
    , theme : Theme
    , aspectRatio : AspectRatio
    , showControls : Bool
    , keyboardShortcuts : Bool
    , showKeyboardHelp : Bool
    , thumbnailVttUrl : Maybe String
    , enableTouchGestures : Bool
    , captionStyle : CaptionStyle
    , externalCaptionTracks : List ExternalCaptionTrack
    }


{-| Colour theme for the player controls.

  - `Light` — light controls for use on dark video content (default).
  - `Dark` — dark controls for use on light content.
  - `Custom` — fully customisable via CSS custom-property values.

-}
type Theme
    = Light
    | Dark
    | Custom ThemeVars


{-| CSS custom-property values for a custom theme.

All values are CSS colour strings (hex, rgb, rgba, named colours, etc.).

  - `controlsBg` — background colour of individual control elements.
  - `controlsFg` — icon and text colour within the controls bar.
  - `progressFill` — playback-progress fill colour on the seek bar.
  - `progressThumb` — seek bar scrubber thumb colour.
  - `loadedFill` — buffered-range fill colour on the seek bar.
  - `controlsBgGradient` — dark gradient stop behind the controls bar
    (the gradient goes from this colour at the bottom to transparent).
  - `errorBg` — background colour of the error overlay.
  - `errorFg` — text colour of the error overlay.
  - `spinnerColor` — buffering spinner stroke colour.
  - `liveBg` — background colour of the LIVE badge.
  - `liveFg` — text colour of the LIVE badge.
  - `cueBg` — background colour behind caption cue boxes.
  - `cueFg` — text colour of caption cue boxes.
  - `thumbBg` — background colour of the seek thumbnail container.

-}
type alias ThemeVars =
    { controlsBg : String
    , controlsFg : String
    , progressFill : String
    , progressThumb : String
    , loadedFill : String
    , controlsBgGradient : String
    , errorBg : String
    , errorFg : String
    , spinnerColor : String
    , liveBg : String
    , liveFg : String
    , cueBg : String
    , cueFg : String
    , thumbBg : String
    }


{-| Aspect ratio constraint for the player container.

The player maintains this ratio by setting `padding-top` on the
container, allowing it to be responsive without JavaScript layout.

  - `Ratio16x9` — standard widescreen (default).
  - `Ratio4x3` — classic TV ratio.
  - `Ratio21x9` — cinematic widescreen.
  - `CustomRatio f` — arbitrary ratio as a decimal (e.g. `1.0` for square).

-}
type AspectRatio
    = Ratio16x9
    | Ratio4x3
    | Ratio21x9
    | CustomRatio Float


{-| Font size preset for caption cue boxes. -}
type CaptionFontSize
    = CaptionSmall
    | CaptionMedium
    | CaptionLarge


{-| Caption display style configuration.

  - `fontSize` — font size preset for caption cue boxes.
  - `backgroundOpacity` — opacity of the caption cue background, 0.0–1.0.

-}
type alias CaptionStyle =
    { fontSize : CaptionFontSize
    , backgroundOpacity : Float
    }


{-| An externally-provided caption or subtitle track to inject into the
video element as a `<track>` element.

Tracks added this way are automatically discovered by the player after the
media element loads, and will appear in the captions menu alongside any
tracks embedded in the stream.

  - `url` — URL of the WebVTT subtitle or caption file.
  - `label` — human-readable label shown in the captions menu (e.g. "English").
  - `language` — BCP 47 language tag (e.g. `"en"`, `"fr-CA"`).
  - `kind` — track kind: `"subtitles"`, `"captions"`, `"descriptions"`,
    `"chapters"`, or `"metadata"`.
  - `default` — whether the browser should activate this track by default.
    At most one track should have `default = True`.

-}
type alias ExternalCaptionTrack =
    { url : String
    , label : String
    , language : String
    , kind : String
    , default : Bool
    }



-- DEFAULT CONFIG


{-| Default configuration for a 16:9 player with Light theme and no
autoplay. Requires a `MediaId` and a `Source`.

    Video.Config.defaultConfig (Media.id "my-video") (Video.Source.hls manifestUrl)

-}
defaultConfig : Media.MediaId -> Source -> Config
defaultConfig mediaId source =
    { source = source
    , sources = []
    , mediaId = mediaId
    , autoplay = False
    , muted = False
    , loop = False
    , poster = Nothing
    , preload = Media.PreloadMetadata
    , theme = Light
    , aspectRatio = Ratio16x9
    , showControls = True
    , keyboardShortcuts = True
    , showKeyboardHelp = True
    , thumbnailVttUrl = Nothing
    , enableTouchGestures = True
    , captionStyle = { fontSize = CaptionMedium, backgroundOpacity = 0.8 }
    , externalCaptionTracks = []
    }
