import Video.Controls
import Video.Source exposing (Source(..))
import Video.Thumbnail



-- TYPES


{-| Opaque player state. Store in your model and pass to `update`,
`subscriptions`, and `view`. -}
type State
    = State (StateRecord)


type alias StateRecord =
    { mediaState : Media.State
    , hlsId : Maybe Hls.HlsId
    , dashId : Maybe Dash.PlayerId
    , availableQualities : List QualityLevel
    , currentQualityIndex : Int
    , captionTracks : List Video.Caption.Track
    , captionTrackInfos : List Media.Track.TrackInfo
    , activeCaptionTrack : Maybe Int
    , activeCaptionTrackIndex : Maybe Media.Track.TrackIndex
    , activeCues : List Media.Track.Cue
    , controlsVisible : Bool
    , hideControlsDebounce : Debounce.Debounce ()
    , isFullscreen : Bool
    , isPip : Bool
    , seekHovering : Bool
    , thumbnailTime : Float
    , thumbnailPosition : Float
    , thumbnailDataUrl : Maybe String
    , thumbnailCapturing : Bool
    , thumbnailSprites : List ThumbnailSprite
    , thumbnailSpriteClip : Maybe { x : Int, y : Int, w : Int, h : Int }
    , isCompact : Bool
    , activeMenu : Maybe ActiveMenu
    , tracksDiscovered : Bool
    , isLive : Bool
    , hasError : Bool
    , lastError : Maybe Media.Error
    , customErrorMsg : Maybe String
    , remoteAvailable : Bool
    , chapters : List ChapterCue
    , touchStartX : Maybe Float
    , touchStartY : Maybe Float
    , firstFrameEmitted : Bool
    , wasBuffering : Bool
    , lastProgressPct : Int
    , isDraggingSeek : Bool
    , seekBarLeft : Float
    , seekBarWidth : Float
    , seekBarDragStartClientX : Float
    , seekBarDragStartTime : Float
    , accessibilityAnnouncement : String
    , retryCount : Int
    , mutedByAutoplayFallback : Bool
    , lastTapTime : Maybe Float
    , lastTapX : Maybe Float
    , playerWidth : Float
    , keyboardHelpVisible : Bool
    , pendingFullscreen : Bool
    , fullscreenUnavailable : Bool
    }


{-| A quality level exposed to the application.

Combines information from HLS levels or DASH representations into a
uniform record.

-}
type alias QualityLevel =
    { index : Int
    , label : String
    , bitrate : Int
    , width : Int
    , height : Int
    }


{-| A chapter cue extracted from a chapters text track.

  - `startTime` — chapter start time in seconds.
  - `endTime` — chapter end time in seconds.
  - `title` — chapter title from the cue text.

-}
type alias ChapterCue =
    { startTime : Float
    , endTime : Float
    , title : String
    }


{-| A single sprite entry from a WebVTT thumbnail sprite sheet.

  - `startTime` / `endTime` — the video time range this sprite covers.
  - `url` — URL of the sprite image.
  - `x`, `y`, `w`, `h` — pixel region within the sprite image.

-}
type alias ThumbnailSprite =
    { startTime : Float
    , endTime : Float
    , url : String
    , x : Int
    , y : Int
    , w : Int
    , h : Int
    }


{-| The currently active dropdown menu. -}
type ActiveMenu
    = QualityMenu
    | SpeedMenu
    | CaptionsMenu


{-| All messages the player handles. -}
type Msg
    = -- Media element events
      GotMediaState Media.State
    | GotActiveCues (List Media.Track.Cue)
      -- Playback controls
    | PlayPause
    | SeekTo Float
    | SetVolume Float
    | ToggleMute
    | SetPlaybackRate Float
    | ToggleFullscreen
    | TogglePip
    | ToggleRemotePlayback
      -- Quality and captions
    | SetQuality Int
    | SetCaptionTrack (Maybe Int)
      -- Controls bar visibility
    | ShowControls
    | HideControls
    | ControlsActivity
    | HideControlsDebounce (Debounce.Msg ())
      -- Dropdown menu open/close
    | OpenMenu ActiveMenu
    | CloseMenu
      -- Keyboard input
    | KeyDown String
      -- Error recovery
    | Retry
    | DoRetry
      -- Caption track discovery and cue subscription
    | GotTrackInfo (Result Media.Error (List Media.Track.TrackInfo))
    | CueChanged
      -- Buffered ranges fetch
    | FetchBuffered
    | GotBuffered (Result Media.Error (List Media.TimeRange))
      -- Observer results
    | GotPlayerWidth Float
    | GotPlayerVisible Bool
    | GotIsLive Bool
      -- Streaming internals
    | HlsMsg HlsInternalMsg
    | DashMsg DashInternalMsg
      -- Thumbnail preview
    | ThumbnailMsg ThumbnailInternalMsg
      -- Fullscreen / PiP state sync
    | SyncFullscreenState
    | GotFullscreenChange Bool
    | GotPipChange Bool
      -- Remote playback availability
    | GotRemoteAvailability Bool
      -- Thumbnail frame capture
    | GotThumbnailFrame (Result Media.Error String)
    | GotThumbnailSprites (Result Http.Error (List ThumbnailSprite))
      -- Chapter cues
    | GotChapterCues (Result Media.Error (List Media.Track.Cue))
      -- Touch gestures
    | TouchStart Float Float
    | TouchEnd Float Float Float
      -- Drag-to-scrub
    | SeekDragStart Float Float Float
    | SeekDragEnd
    | PlayerMouseMove Float
    | SeekTouchDragStart Float Float
    | SeekTouchDragMove Float
      -- Autoplay failure handling
    | AutoplayBlocked
    | DismissAutoplayNotice
      -- Keyboard help overlay
    | ToggleKeyboardHelp


{-| Internal HLS messages. -}
type HlsInternalMsg
    = HlsCreated Hls.HlsId
    | HlsManifestParsed (List Hls.Level)
    | HlsLevelSwitched Hls.Level
    | HlsError String Bool
    | HlsFragLoaded


{-| Internal DASH messages. -}
type DashInternalMsg
    = DashCreated Dash.PlayerId
    | DashManifestLoaded Dash.StreamInfo
    | DashQualitiesLoaded (List QualityLevel)
    | DashRepresentationSwitched Dash.Representation
    | DashError String
    | DashStreamInitialized


{-| Internal thumbnail preview messages. -}
type ThumbnailInternalMsg
    = ThumbnailHoverAt Float Float
    | ThumbnailHoverLeave


{-| Events communicated to the parent after significant player state changes. -}
type OutMsg
    = Ready
    | PlaybackError Media.Error
    | QualityLevelsLoaded (List QualityLevel)
    | Ended
    | RemotePlaybackRequested
    | FirstFrameReady
    | Rebuffering
    | BufferingResolved
    | QualityChanged QualityLevel
    | ChapterChanged (Maybe ChapterCue)
    | PlaybackProgress Float



-- CONSTANTS


{-| Debounce config for the 3-second auto-hide timer on the controls bar. -}
hideControlsConfig : Debounce.Config () Msg
hideControlsConfig =
    Debounce.config
        { delay = 3000
        , onEmit = \_ -> HideControls
        , toMsg = HideControlsDebounce
        }


progressMilestones : List Int
progressMilestones =
    [ 1, 25, 50, 75, 95, 100 ]



-- INIT


{-| Initialise the player.

Creates the initial state and launches the appropriate streaming pipeline
based on the source type. The parent should wire the returned `Cmd Msg`
into its own `Cmd msg` using `Cmd.map`.

    type Msg
        = VideoMsg Video.Msg
        | ...

    init : ( Model, Cmd Msg )
    init =
        let
            ( videoState, videoCmd ) =
                Video.init config
        in
        ( { videoState = videoState }, Cmd.map VideoMsg videoCmd )

-}
init : Config -> ( State, Cmd Msg )
init config =
    let
        initialState =
            State
                { mediaState = Media.defaultState
                , hlsId = Nothing
                , dashId = Nothing
                , availableQualities = []
                , currentQualityIndex = -1
                , captionTracks = []
                , captionTrackInfos = []
                , activeCaptionTrack = Nothing
                , activeCaptionTrackIndex = Nothing
                , activeCues = []
                , controlsVisible = True
                , hideControlsDebounce = Debounce.init 3000
                , isFullscreen = False
                , isPip = False
                , seekHovering = False
                , thumbnailTime = 0
                , thumbnailPosition = 0
                , thumbnailDataUrl = Nothing
                , thumbnailCapturing = False
                , thumbnailSprites = []
                , thumbnailSpriteClip = Nothing
                , isCompact = False
                , activeMenu = Nothing
                , tracksDiscovered = False
                , isLive = False
                , hasError = False
                , lastError = Nothing
                , customErrorMsg = Nothing
                , remoteAvailable = False
                , chapters = []
                , touchStartX = Nothing
                , touchStartY = Nothing
                , firstFrameEmitted = False
                , wasBuffering = False
                , lastProgressPct = 0
                , isDraggingSeek = False
                , seekBarLeft = 0.0
                , seekBarWidth = 0.0
                , seekBarDragStartClientX = 0.0
                , seekBarDragStartTime = 0.0
                , accessibilityAnnouncement = ""
                , retryCount = 0
                , mutedByAutoplayFallback = False
                , lastTapTime = Nothing
                , lastTapX = Nothing
                , playerWidth = 0.0
                , keyboardHelpVisible = False
                , pendingFullscreen = False
                , fullscreenUnavailable = False
                }

        streamingCmd =
            case config.source of
                Plain _ _ ->
                    Cmd.none

                Hls _ ->
                    Task.attempt
                        (\result ->
                            case result of
                                Ok hlsId ->
                                    HlsMsg (HlsCreated hlsId)

                                Err _ ->
                                    HlsMsg (HlsError "Failed to create hls.js instance" True)
                        )
                        (Hls.create Hls.defaultConfig)

                Dash _ _ ->
                    Task.attempt
                        (\result ->
                            case result of
                                Ok playerId ->
                                    DashMsg (DashCreated playerId)

                                Err _ ->
                                    DashMsg (DashError "Failed to create dash.js instance")
                        )
                        Dash.create

        remoteCmd =
            Media.RemotePlayback.watchRemoteAvailability config.mediaId GotRemoteAvailability

        spriteCmd =
            case config.thumbnailVttUrl of
                Nothing ->
                    Cmd.none

                Just url ->
                    Http.get
                        { url = url
                        , expect =
                            Http.expectString
                                (\result ->
                                    GotThumbnailSprites (Result.map parseSpriteVtt result)
                                )
                        }
    in
    ( initialState, Cmd.batch [ streamingCmd, remoteCmd, spriteCmd ] )



-- SUBSCRIPTIONS


{-| Wire browser observers into your app's subscriptions.

Handles resize-based compact mode switching (width < 480 px) and
intersection-based auto-pause when the player scrolls out of view.

    subscriptions : Model -> Sub Msg
    subscriptions model =
        Sub.map VideoMsg (Video.subscriptions config model.videoState)

-}
subscriptions : Config -> State -> Sub Msg
subscriptions config _ =
    let
        containerId =
            Media.unwrapId config.mediaId ++ "-player"
    in
    Sub.batch
        [ Observer.Resize.onSize containerId
            (\width _ -> GotPlayerWidth width)
        , Observer.Intersection.onVisible (Media.unwrapId config.mediaId)
            GotPlayerVisible
        ]



-- UPDATE


{-| Update the player state.

Handle a `Video.Msg` and return the updated state, any commands, and
an optional `OutMsg` for significant events (errors, quality changes,
remote playback requests, analytics milestones).

-}
update : Config -> Msg -> State -> ( State, Cmd Msg, Maybe OutMsg )
update config msg (State s) =
    case msg of
        GotMediaState mediaState ->
            let
                isNewError =
                    s.mediaState.error == Nothing && mediaState.error /= Nothing

                isFirstFrame =
                    not s.firstFrameEmitted
                        && mediaState.readyState == Media.HaveEnoughData

                nowBuffering =
                    not mediaState.paused
                        && (mediaState.readyState == Media.HaveFutureData
                                || mediaState.readyState == Media.HaveCurrentData
                           )

                rebufferingStarted =
                    nowBuffering && not s.wasBuffering

                rebufferingResolved =
                    not nowBuffering && s.wasBuffering

                currentPct =
                    if mediaState.duration > 0 then
                        floor (mediaState.currentTime / mediaState.duration * 100)
                    else
                        0

                nextMilestone =
                    List.filter
                        (\m -> m > s.lastProgressPct && m <= currentPct)
                        progressMilestones
                        |> List.head

                newLastProgressPct =
                    Maybe.withDefault s.lastProgressPct
                        (Maybe.map (\_ -> currentPct) nextMilestone)

                prevChapter =
                    activeChapterAt s.mediaState.currentTime s.chapters

                currentChapter =
                    activeChapterAt mediaState.currentTime s.chapters

                chapterChanged =
                    prevChapter /= currentChapter

                analyticsOutMsg =
                    if isFirstFrame then
                        Just FirstFrameReady
                    else if rebufferingStarted then
                        Just Rebuffering
                    else if rebufferingResolved then
                        Just BufferingResolved
                    else if chapterChanged then
                        Just (ChapterChanged currentChapter)
                    else
                        Maybe.map (\m -> PlaybackProgress (toFloat m / 100)) nextMilestone

                outMsg =
                    if mediaState.ended then
                        Just Ended
                    else if isNewError then
                        Maybe.map PlaybackError mediaState.error
                    else
                        analyticsOutMsg

                shouldDiscoverTracks =
                    not s.tracksDiscovered
                        && mediaState.readyState /= Media.HaveNothing

                trackCmd =
                    if shouldDiscoverTracks then
                        Cmd.batch
                            [ Task.attempt GotTrackInfo
                                (Media.Track.listTracks config.mediaId)
                            , Task.perform GotIsLive
                                (Media.isLive config.mediaId)
                            ]
                    else
                        Cmd.none

                announcement =
                    if isNewError then "Playback error" else s.accessibilityAnnouncement
            in
            ( State
                { s
                    | mediaState = mediaState
                    , tracksDiscovered = s.tracksDiscovered || shouldDiscoverTracks
                    , hasError = mediaState.error /= Nothing
                    , lastError = mediaState.error
                    , firstFrameEmitted = s.firstFrameEmitted || isFirstFrame
                    , wasBuffering = nowBuffering
                    , lastProgressPct = newLastProgressPct
                    , retryCount = if isFirstFrame then 0 else s.retryCount
                    , accessibilityAnnouncement = announcement
                }
            , trackCmd
            , outMsg
            )

        GotActiveCues cues ->
            ( State { s | activeCues = cues }, Cmd.none, Nothing )

        PlayPause ->
            let
                cmd =
                    if s.mediaState.paused then
                        Task.attempt
                            (\result ->
                                case result of
                                    Ok _ -> GotMediaState s.mediaState
                                    Err _ -> AutoplayBlocked
                            )
                            (Media.play config.mediaId)
                    else
                        Media.pause config.mediaId
            in
            ( State { s | accessibilityAnnouncement = if s.mediaState.paused then "Playing" else "Paused" }
            , cmd
            , Nothing
            )

        SeekTo time ->
            ( State { s | accessibilityAnnouncement = "Seeked to " ++ formatAnnounceTime time }
            , Media.seek config.mediaId time
            , Nothing
            )

        SetVolume vol ->
            ( State s, Media.setVolume config.mediaId (max 0 (min 1 vol)), Nothing )

        ToggleMute ->
            ( State s
            , Media.setMuted config.mediaId (not s.mediaState.muted)
            , Nothing
            )

        SetPlaybackRate rate ->
            let
                clamped =
                    max 0.25 (min 2.0 rate)
            in
            ( State { s | activeMenu = Nothing, accessibilityAnnouncement = "Speed " ++ String.fromFloat clamped ++ "x" }
            , Media.setPlaybackRate config.mediaId clamped
            , Nothing
            )

        ToggleFullscreen ->
            let
                cmd =
                    if s.isFullscreen then
                        Media.Video.exitFullscreen
                    else
                        Media.Video.requestFullscreen config.mediaId
            in
            ( State { s | pendingFullscreen = not s.isFullscreen }, cmd, Nothing )

        TogglePip ->
            let
                cmd =
                    if s.isPip then
                        Task.attempt
                            (\result ->
                                GotPipChange
                                    (case result of
                                        Ok _ -> False
                                        Err _ -> s.isPip
                                    )
                            )
                            Media.Video.exitPictureInPicture
                    else
                        Task.attempt
                            (\result ->
                                GotPipChange
                                    (case result of
                                        Ok _ -> True
                                        Err _ -> s.isPip
                                    )
                            )
                            (Media.Video.enterPictureInPicture config.mediaId)
            in
            ( State s, cmd, Nothing )

        ToggleRemotePlayback ->
            ( State s
            , Task.attempt (\_ -> ControlsActivity)
                (Media.RemotePlayback.prompt config.mediaId)
            , Just RemotePlaybackRequested
            )

        SetQuality index ->
            let
                cmd =
                    case s.hlsId of
                        Just hlsId ->
                            Hls.setCurrentLevel hlsId index

                        Nothing ->
                            s.dashId
                                |> Maybe.map
                                    (\dashId ->
                                        Dash.setRepresentation dashId Dash.Video index
                                    )
                                |> Maybe.withDefault Cmd.none
            in
            ( State { s | currentQualityIndex = index, activeMenu = Nothing, accessibilityAnnouncement = "Quality changed" }
            , cmd
            , Nothing
            )

        SetCaptionTrack maybeIndex ->
            maybeIndex
                |> Maybe.map (\n -> enableCaptionTrack config n s)
                |> Maybe.withDefault (disableCaptionTrack config s)

        ShowControls ->
            let
                ( newDebounce, cmd ) =
                    Debounce.push hideControlsConfig () s.hideControlsDebounce
            in
            ( State { s | controlsVisible = True, hideControlsDebounce = newDebounce }
            , cmd
            , Nothing
            )

        HideControls ->
            ( State
                { s
                    | controlsVisible = False
                    , hideControlsDebounce = Debounce.cancel s.hideControlsDebounce
                    , isDraggingSeek = False
                }
            , Cmd.none
            , Nothing
            )

        ControlsActivity ->
            let
                ( newDebounce, cmd ) =
                    Debounce.push hideControlsConfig () s.hideControlsDebounce
            in
            ( State { s | controlsVisible = True, hideControlsDebounce = newDebounce }
            , cmd
            , Nothing
            )

        HideControlsDebounce debounceMsg ->
            let
                ( newDebounce, cmd ) =
                    Debounce.update hideControlsConfig debounceMsg s.hideControlsDebounce
            in
            ( State { s | hideControlsDebounce = newDebounce }, cmd, Nothing )

        OpenMenu menu ->
            ( State { s | activeMenu = Just menu }, Cmd.none, Nothing )

        CloseMenu ->
            ( State { s | activeMenu = Nothing }, Cmd.none, Nothing )

        KeyDown key ->
            handleKeyDown config key s

        Retry ->
            if s.retryCount >= 3 then
                ( State { s | hasError = True }
                , Cmd.none
                , Just (PlaybackError (Maybe.withDefault Media.NetworkError s.lastError))
                )
            else
                let
                    backoffMs =
                        s.retryCount * 2000

                    retryCmd =
                        Task.perform (\_ -> DoRetry) (Process.sleep (toFloat backoffMs))
                in
                ( State { s | retryCount = s.retryCount + 1 }, retryCmd, Nothing )

        DoRetry ->
            let
                cmd =
                    case config.source of
                        Plain _ _ ->
                            Media.load config.mediaId

                        Hls url ->
                            s.hlsId
                                |> Maybe.map
                                    (\hlsId ->
                                        Task.attempt (\_ -> ControlsActivity)
                                            (Hls.loadSource hlsId url)
                                    )
                                |> Maybe.withDefault Cmd.none

                        Dash url _ ->
                            case s.dashId of
                                Just dashId ->
                                    Task.attempt (\_ -> ControlsActivity)
                                        (Dash.initialize dashId config.mediaId url False)

                                Nothing ->
                                    Media.load config.mediaId
            in
            ( State { s | hasError = False, lastError = Nothing, customErrorMsg = Nothing }, cmd, Nothing )

        GotTrackInfo result ->
            let
                trackInfos =
                    Result.withDefault [] result

                tracks =
                    convertTrackInfos trackInfos

                chaptersCmd =
                    trackInfos
                        |> List.filter
                            (\info ->
                                Media.Track.trackKindToString info.kind == "chapters"
                            )
                        |> List.head
                        |> Maybe.map
                            (\info ->
                                Task.attempt GotChapterCues
                                    (Media.Track.getActiveCues config.mediaId info.index)
                            )
                        |> Maybe.withDefault Cmd.none
            in
            ( State { s | captionTrackInfos = trackInfos, captionTracks = tracks }
            , chaptersCmd
            , Nothing
            )

        CueChanged ->
            let
                cmd =
                    s.activeCaptionTrackIndex
                        |> Maybe.map
                            (\trackIdx ->
                                Task.attempt
                                    (\result ->
                                        GotActiveCues (Result.withDefault [] result)
                                    )
                                    (Media.Track.getActiveCues config.mediaId trackIdx)
                            )
                        |> Maybe.withDefault Cmd.none
            in
            ( State s, cmd, Nothing )

        FetchBuffered ->
            ( State s
            , Task.attempt
                (\result -> GotBuffered (Result.map .buffered result))
                (Media.getState config.mediaId)
            , Nothing
            )

        GotBuffered result ->
            let
                ranges =
                    Result.withDefault s.mediaState.buffered result

                ms =
                    s.mediaState
            in
            ( State { s | mediaState = { ms | buffered = ranges } }
            , Cmd.none
            , Nothing
            )

        GotPlayerWidth width ->
            ( State { s | isCompact = width < 480, playerWidth = width }, Cmd.none, Nothing )

        GotPlayerVisible isVisible ->
            let
                cmd =
                    if not isVisible && not s.mediaState.paused then
                        Media.pause config.mediaId
                    else
                        Cmd.none
            in
            ( State s, cmd, Nothing )

        GotIsLive live ->
            ( State { s | isLive = live }, Cmd.none, Nothing )

        HlsMsg hlsMsg ->
            updateHls config hlsMsg s

        DashMsg dashMsg ->
            updateDash config dashMsg s

        ThumbnailMsg thumbMsg ->
            updateThumbnail config thumbMsg s

        SyncFullscreenState ->
            ( State s
            , Task.perform GotFullscreenChange Media.Video.isFullscreen
            , Nothing
            )

        GotFullscreenChange isFs ->
            let
                nowUnavailable =
                    s.pendingFullscreen && not isFs && not s.isFullscreen
            in
            ( State
                { s
                    | isFullscreen = isFs
                    , pendingFullscreen = False
                    , fullscreenUnavailable =
                        if nowUnavailable then True else s.fullscreenUnavailable
                }
            , Cmd.none
            , Nothing
            )

        ToggleKeyboardHelp ->
            ( State { s | keyboardHelpVisible = not s.keyboardHelpVisible }
            , Cmd.none
            , Nothing
            )

        GotPipChange active ->
            ( State { s | isPip = active }, Cmd.none, Nothing )

        GotRemoteAvailability available ->
            ( State { s | remoteAvailable = available }, Cmd.none, Nothing )

        GotThumbnailFrame result ->
            ( State
                { s
                    | thumbnailDataUrl = Result.toMaybe result
                    , thumbnailCapturing = False
                }
            , Cmd.none
            , Nothing
            )

        GotThumbnailSprites result ->
            ( State { s | thumbnailSprites = Result.withDefault [] result }
            , Cmd.none
            , Nothing
            )

        GotChapterCues result ->
            let
                cues =
                    Result.withDefault [] result

                chaptersList =
                    List.map cueToChapter cues
            in
            ( State { s | chapters = chaptersList }, Cmd.none, Nothing )

        TouchStart x y ->
            ( State { s | touchStartX = Just x, touchStartY = Just y }, Cmd.none, Nothing )

        TouchEnd x y timestamp ->
            handleTouchEnd config x y timestamp s

        SeekDragStart offsetX barLeft barWidth ->
            let
                time =
                    if barWidth > 0 then
                        offsetX / barWidth * s.mediaState.duration
                    else
                        s.mediaState.currentTime
            in
            ( State { s | isDraggingSeek = True, seekBarLeft = barLeft, seekBarWidth = barWidth }
            , Media.seek config.mediaId time
            , Nothing
            )

        SeekDragEnd ->
            ( State { s | isDraggingSeek = False }, Cmd.none, Nothing )

        PlayerMouseMove clientX ->
            let
                ( newDebounce, debounceCmd ) =
                    Debounce.push hideControlsConfig () s.hideControlsDebounce

                seekCmd =
                    if s.isDraggingSeek && s.seekBarWidth > 0 then
                        let
                            relX =
                                clientX - s.seekBarLeft

                            clamped =
                                max 0 (min s.seekBarWidth relX)

                            time =
                                clamped / s.seekBarWidth * s.mediaState.duration
                        in
                        Media.seek config.mediaId time
                    else
                        Cmd.none
            in
            ( State { s | controlsVisible = True, hideControlsDebounce = newDebounce }
            , Cmd.batch [ debounceCmd, seekCmd ]
            , Nothing
            )

        SeekTouchDragStart startClientX barWidth ->
            ( State
                { s
                    | isDraggingSeek = True
                    , seekBarWidth = barWidth
                    , seekBarDragStartClientX = startClientX
                    , seekBarDragStartTime = s.mediaState.currentTime
                }
            , Cmd.none
            , Nothing
            )

        SeekTouchDragMove currentClientX ->
            if not s.isDraggingSeek || s.seekBarWidth <= 0 then
                ( State s, Cmd.none, Nothing )
            else
                let
                    delta =
                        (currentClientX - s.seekBarDragStartClientX) / s.seekBarWidth * s.mediaState.duration

                    time =
                        max 0 (min s.mediaState.duration (s.seekBarDragStartTime + delta))
                in
                ( State s, Media.seek config.mediaId time, Nothing )

        AutoplayBlocked ->
            ( State { s | mutedByAutoplayFallback = True }
            , Cmd.batch
                [ Media.setMuted config.mediaId True
                , Task.attempt (\_ -> GotMediaState s.mediaState) (Media.play config.mediaId)
                ]
            , Nothing
            )

        DismissAutoplayNotice ->
            ( State { s | mutedByAutoplayFallback = False }
            , Media.setMuted config.mediaId False
            , Nothing
            )


enableCaptionTrack : Config -> Int -> StateRecord -> ( State, Cmd Msg, Maybe OutMsg )
enableCaptionTrack config n s =
    let
        maybeInfo =
            List.drop n s.captionTrackInfos |> List.head

        clearCmd =
            case s.activeCaptionTrackIndex of
                Just idx ->
                    Media.Track.clearCueChangeHandler config.mediaId idx

                Nothing ->
                    Cmd.none

        enableCmd =
            maybeInfo
                |> Maybe.map
                    (\info ->
                        Task.attempt (\_ -> ControlsActivity)
                            (Media.Track.setTrackMode config.mediaId
                                info.index
                                Media.Track.Showing
                            )
                    )
                |> Maybe.withDefault Cmd.none

        handlerCmd =
            maybeInfo
                |> Maybe.map
                    (\info ->
                        Media.Track.setCueChangeHandler
                            config.mediaId
                            info.index
                            CueChanged
                    )
                |> Maybe.withDefault Cmd.none

        newTrackIndex =
            Maybe.map .index maybeInfo
    in
    ( State
        { s
            | activeCaptionTrack = Just n
            , activeCaptionTrackIndex = newTrackIndex
            , activeCues = []
            , activeMenu = Nothing
        }
    , Cmd.batch [ clearCmd, enableCmd, handlerCmd ]
    , Nothing
    )


disableCaptionTrack : Config -> StateRecord -> ( State, Cmd Msg, Maybe OutMsg )
disableCaptionTrack config s =
    let
        clearCmd =
            s.activeCaptionTrackIndex
                |> Maybe.map
                    (\trackIdx ->
                        Cmd.batch
                            [ Task.attempt (\_ -> ControlsActivity)
                                (Media.Track.setTrackMode config.mediaId
                                    trackIdx
                                    Media.Track.Disabled
                                )
                            , Media.Track.clearCueChangeHandler config.mediaId trackIdx
                            ]
                    )
                |> Maybe.withDefault Cmd.none
    in
    ( State
        { s
            | activeCaptionTrack = Nothing
            , activeCaptionTrackIndex = Nothing
            , activeCues = []
            , activeMenu = Nothing
        }
    , clearCmd
    , Nothing
    )


cycleCaptionTrack : Config -> StateRecord -> ( State, Cmd Msg, Maybe OutMsg )
cycleCaptionTrack config s =
    case s.activeCaptionTrack of
        Nothing ->
            case List.head s.captionTrackInfos of
                Just _ ->
                    enableCaptionTrack config 0 s

                Nothing ->
                    ( State s, Cmd.none, Nothing )

        Just _ ->
            disableCaptionTrack config s


handleKeyDown : Config -> String -> StateRecord -> ( State, Cmd Msg, Maybe OutMsg )
handleKeyDown config key s =
    let
        seekBy delta =
            Media.seek config.mediaId
                (max 0
                    (min s.mediaState.duration
                        (s.mediaState.currentTime + delta)
                    )
                )

        adjustVol delta =
            Media.setVolume config.mediaId
                (max 0 (min 1 (s.mediaState.volume + delta)))

        togglePlay =
            if s.mediaState.paused then
                Task.attempt (\_ -> GotMediaState s.mediaState)
                    (Media.play config.mediaId)
            else
                Media.pause config.mediaId
    in
    case key of
        " " ->
            ( State s, togglePlay, Nothing )

        "k" ->
            ( State s, togglePlay, Nothing )

        "K" ->
            ( State s, togglePlay, Nothing )

        "ArrowLeft" ->
            ( State s, seekBy -10, Nothing )

        "j" ->
            ( State s, seekBy -10, Nothing )

        "J" ->
            ( State s, seekBy -10, Nothing )

        "ArrowRight" ->
            ( State s, seekBy 10, Nothing )

        "l" ->
            ( State s, seekBy 10, Nothing )

        "L" ->
            ( State s, seekBy 10, Nothing )

        "ArrowUp" ->
            ( State s, adjustVol 0.1, Nothing )

        "ArrowDown" ->
            ( State s, adjustVol -0.1, Nothing )

        "m" ->
            ( State s
            , Media.setMuted config.mediaId (not s.mediaState.muted)
            , Nothing
            )

        "M" ->
            ( State s
            , Media.setMuted config.mediaId (not s.mediaState.muted)
            , Nothing
            )

        "f" ->
            ( State s
            , if s.isFullscreen then
                Media.Video.exitFullscreen
              else
                Media.Video.requestFullscreen config.mediaId
            , Nothing
            )

        "F" ->
            ( State s
            , if s.isFullscreen then
                Media.Video.exitFullscreen
              else
                Media.Video.requestFullscreen config.mediaId
            , Nothing
            )

        "p" ->
            ( State s
            , if s.isPip then
                Task.attempt (\_ -> GotPipChange False) Media.Video.exitPictureInPicture
              else
                Task.attempt (\_ -> GotPipChange True)
                    (Media.Video.enterPictureInPicture config.mediaId)
            , Nothing
            )

        "P" ->
            ( State s
            , if s.isPip then
                Task.attempt (\_ -> GotPipChange False) Media.Video.exitPictureInPicture
              else
                Task.attempt (\_ -> GotPipChange True)
                    (Media.Video.enterPictureInPicture config.mediaId)
            , Nothing
            )

        "Escape" ->
            ( State { s | activeMenu = Nothing, keyboardHelpVisible = False }, Cmd.none, Nothing )

        "?" ->
            if config.showKeyboardHelp then
                ( State { s | keyboardHelpVisible = not s.keyboardHelpVisible }
                , Cmd.none
                , Nothing
                )
            else
                ( State s, Cmd.none, Nothing )

        "c" ->
            cycleCaptionTrack config s

        "C" ->
            cycleCaptionTrack config s

        "<" ->
            ( State s
            , Media.setPlaybackRate config.mediaId
                (max 0.25 (s.mediaState.playbackRate - 0.25))
            , Nothing
            )

        ">" ->
            ( State s
            , Media.setPlaybackRate config.mediaId
                (min 2.0 (s.mediaState.playbackRate + 0.25))
            , Nothing
            )

        "Home" ->
            ( State s, Media.seek config.mediaId 0, Nothing )

        "End" ->
            ( State s, Media.seek config.mediaId s.mediaState.duration, Nothing )

        _ ->
            let
                digitSeek =
                    String.toInt key
                        |> Maybe.andThen
                            (\n ->
                                if n >= 0 && n <= 9 then
                                    Just n
                                else
                                    Nothing
                            )
                        |> Maybe.map
                            (\n ->
                                seekBy
                                    (toFloat n
                                        / 10
                                        * s.mediaState.duration
                                        - s.mediaState.currentTime
                                    )
                            )
            in
            ( State s, Maybe.withDefault Cmd.none digitSeek, Nothing )


handleTouchEnd : Config -> Float -> Float -> Float -> StateRecord -> ( State, Cmd Msg, Maybe OutMsg )
handleTouchEnd config x y timestamp s =
    let
        cleared =
            { s | touchStartX = Nothing, touchStartY = Nothing }
    in
    case ( s.touchStartX, s.touchStartY ) of
        ( Just startX, Just startY ) ->
            let
                dx =
                    x - startX

                dy =
                    y - startY
            in
            if abs dx < 10 && abs dy < 10 then
                handleTap config x timestamp cleared s
            else if dx < -20 then
                -- Swipe left: seek back proportional to duration
                let
                    delta =
                        proportionalSeekDelta s.playerWidth s.mediaState.duration (abs dx)
                in
                ( State cleared
                , Media.seek config.mediaId (max 0 (s.mediaState.currentTime - delta))
                , Nothing
                )
            else if dx > 20 then
                -- Swipe right: seek forward proportional to duration
                let
                    delta =
                        proportionalSeekDelta s.playerWidth s.mediaState.duration dx
                in
                ( State cleared
                , Media.seek config.mediaId (min s.mediaState.duration (s.mediaState.currentTime + delta))
                , Nothing
                )
            else if dy < -20 then
                -- Swipe up: volume up
                ( State cleared
                , Media.setVolume config.mediaId (min 1 (s.mediaState.volume + 0.1))
                , Nothing
                )
            else if dy > 20 then
                -- Swipe down: volume down
                ( State cleared
                , Media.setVolume config.mediaId (max 0 (s.mediaState.volume - 0.1))
                , Nothing
                )
            else
                ( State cleared, Cmd.none, Nothing )

        _ ->
            ( State { s | touchStartX = Nothing, touchStartY = Nothing }, Cmd.none, Nothing )


handleTap : Config -> Float -> Float -> StateRecord -> StateRecord -> ( State, Cmd Msg, Maybe OutMsg )
handleTap config x timestamp cleared s =
    let
        isDoubleTap =
            case s.lastTapTime of
                Just prevTime ->
                    timestamp - prevTime < 300

                Nothing ->
                    False

        playCmd =
            if s.mediaState.paused then
                Task.attempt (\_ -> GotMediaState s.mediaState)
                    (Media.play config.mediaId)
            else
                Media.pause config.mediaId
    in
    if isDoubleTap then
        handleDoubleTap config x cleared s playCmd
    else
        -- Single tap: store for potential double-tap, toggle play
        ( State { cleared | lastTapTime = Just timestamp, lastTapX = Just x }
        , playCmd
        , Nothing
        )


handleDoubleTap : Config -> Float -> StateRecord -> StateRecord -> Cmd Msg -> ( State, Cmd Msg, Maybe OutMsg )
handleDoubleTap config tapX cleared s playCmd =
    let
        isLeft =
            s.playerWidth > 0 && tapX < s.playerWidth * 0.35

        isRight =
            s.playerWidth > 0 && tapX > s.playerWidth * 0.65

        seekDelta =
            proportionalSeekDelta s.playerWidth s.mediaState.duration s.playerWidth

        seekCmd =
            if isLeft then
                Media.seek config.mediaId (max 0 (s.mediaState.currentTime - seekDelta))
            else if isRight then
                Media.seek config.mediaId (min s.mediaState.duration (s.mediaState.currentTime + seekDelta))
            else
                playCmd
    in
    ( State { cleared | lastTapTime = Nothing, lastTapX = Nothing }
    , seekCmd
    , Nothing
    )


proportionalSeekDelta : Float -> Float -> Float -> Float
proportionalSeekDelta playerWidth videoDuration dx =
    let
        rawDelta =
            if playerWidth > 0 then
                abs dx / playerWidth * videoDuration * 0.1
            else
                10.0
    in
    max 5.0 (min 30.0 rawDelta)


updateHls : Config -> HlsInternalMsg -> StateRecord -> ( State, Cmd Msg, Maybe OutMsg )
updateHls config hlsMsg s =
    case hlsMsg of
        HlsCreated hlsId ->
            let
                attachCmd =
                    Task.attempt
                        (\result ->
                            case result of
                                Ok () ->
                                    GotMediaState s.mediaState

                                Err _ ->
                                    HlsMsg (HlsError "Failed to attach hls.js" True)
                        )
                        (Task.andThen
                            (\() -> Hls.attach hlsId config.mediaId)
                            (case config.source of
                                Hls url ->
                                    Hls.loadSource hlsId url

                                _ ->
                                    Task.succeed ()
                            )
                        )

                handlerCmds =
                    Cmd.batch
                        [ Hls.onManifestParsed hlsId
                            (\levels -> HlsMsg (HlsManifestParsed levels))
                        , Hls.onLevelSwitched hlsId
                            (\level -> HlsMsg (HlsLevelSwitched level))
                        , Hls.onError hlsId
                            (\detail fatal -> HlsMsg (HlsError detail fatal))
                        , Hls.onFragLoaded hlsId (HlsMsg HlsFragLoaded)
                        ]
            in
            ( State { s | hlsId = Just hlsId }
            , Cmd.batch [ attachCmd, handlerCmds ]
            , Nothing
            )

        HlsManifestParsed levels ->
            let
                qualities =
                    List.map hlsLevelToQuality levels

                outMsg =
                    if List.isEmpty qualities then
                        Nothing
                    else
                        Just (QualityLevelsLoaded qualities)
            in
            ( State { s | availableQualities = qualities }, Cmd.none, outMsg )

        HlsLevelSwitched level ->
            let
                newIndex =
                    level.index

                outMsg =
                    List.filter (\q -> q.index == newIndex) s.availableQualities
                        |> List.head
                        |> Maybe.map QualityChanged
            in
            ( State { s | currentQualityIndex = newIndex }, Cmd.none, outMsg )

        HlsError _ isFatal ->
            ( State
                { s
                    | hasError = isFatal || s.hasError
                    , lastError =
                        if isFatal then Just Media.NetworkError else s.lastError
                }
            , Cmd.none
            , if isFatal then Just (PlaybackError Media.NetworkError) else Nothing
            )

        HlsFragLoaded ->
            ( State s, Cmd.none, Nothing )


updateDash : Config -> DashInternalMsg -> StateRecord -> ( State, Cmd Msg, Maybe OutMsg )
updateDash config dashMsg s =
    case dashMsg of
        DashCreated playerId ->
            let
                ( url, protData ) =
                    case config.source of
                        Dash manifestUrl pd ->
                            ( manifestUrl, pd )

                        _ ->
                            ( "", Nothing )

                initCmd =
                    Task.attempt
                        (\result ->
                            case result of
                                Ok () ->
                                    GotMediaState s.mediaState

                                Err _ ->
                                    DashMsg (DashError "Failed to initialize dash.js")
                        )
                        (Dash.initialize playerId config.mediaId url config.autoplay)

                protCmd =
                    protData
                        |> Maybe.map
                            (\pd ->
                                Dash.setProtectionData
                                    playerId
                                    pd.keySystem
                                    pd.licenseServer
                            )
                        |> Maybe.withDefault Cmd.none

                handlerCmds =
                    Cmd.batch
                        [ Dash.onManifestLoaded playerId
                            (\info -> DashMsg (DashManifestLoaded info))
                        , Dash.onRepresentationSwitch playerId Dash.Video
                            (\repr -> DashMsg (DashRepresentationSwitched repr))
                        , Dash.onError playerId
                            (\err -> DashMsg (DashError err))
                        , Dash.onStreamInitialized playerId
                            (DashMsg DashStreamInitialized)
                        ]
            in
            ( State { s | dashId = Just playerId }
            , Cmd.batch [ initCmd, protCmd, handlerCmds ]
            , Nothing
            )

        DashManifestLoaded _ ->
            let
                fetchReprs =
                    s.dashId
                        |> Maybe.map
                            (\playerId ->
                                Task.perform
                                    (\reprs ->
                                        DashMsg
                                            (DashQualitiesLoaded
                                                (List.map dashReprToQuality reprs)
                                            )
                                    )
                                    (Dash.getRepresentations playerId Dash.Video)
                            )
                        |> Maybe.withDefault Cmd.none
            in
            ( State s, fetchReprs, Nothing )

        DashQualitiesLoaded qualities ->
            ( State { s | availableQualities = qualities }
            , Cmd.none
            , if List.isEmpty qualities then
                Nothing
              else
                Just (QualityLevelsLoaded qualities)
            )

        DashRepresentationSwitched repr ->
            let
                newIndex =
                    repr.index

                outMsg =
                    List.filter (\q -> q.index == newIndex) s.availableQualities
                        |> List.head
                        |> Maybe.map QualityChanged
            in
            ( State { s | currentQualityIndex = newIndex }, Cmd.none, outMsg )

        DashError errMsg ->
            let
                errLower =
                    String.toLower errMsg

                isDrmError =
                    String.contains "license" errLower
                        || String.contains "key" errLower
                        || String.contains "drm" errLower
                        || String.contains "protection" errLower

                errorText =
                    if isDrmError then
                        "DRM license acquisition failed. Check your connection and try again."
                    else
                        "Playback error"
            in
            ( State
                { s
                    | hasError = True
                    , lastError = Just Media.NetworkError
                    , customErrorMsg = Just errorText
                }
            , Cmd.none
            , Just (PlaybackError Media.NetworkError)
            )

        DashStreamInitialized ->
            ( State s, Cmd.none, Just Ready )


updateThumbnail : Config -> ThumbnailInternalMsg -> StateRecord -> ( State, Cmd Msg, Maybe OutMsg )
updateThumbnail config thumbMsg s =
    case thumbMsg of
        ThumbnailHoverAt time position ->
            case findSpriteAt time s.thumbnailSprites of
                Just sprite ->
                    ( State
                        { s
                            | seekHovering = True
                            , thumbnailTime = time
                            , thumbnailPosition = position
                            , thumbnailDataUrl = Just sprite.url
                            , thumbnailCapturing = False
                            , thumbnailSpriteClip = Just { x = sprite.x, y = sprite.y, w = sprite.w, h = sprite.h }
                        }
                    , Cmd.none
                    , Nothing
                    )

                Nothing ->
                    let
                        shouldCapture =
                            not s.thumbnailCapturing && List.isEmpty s.thumbnailSprites

                        captureCmd =
                            if shouldCapture then
                                Task.attempt GotThumbnailFrame
                                    (Media.Capture.captureFrameAt config.mediaId time)
                            else
                                Cmd.none
                    in
                    ( State
                        { s
                            | seekHovering = True
                            , thumbnailTime = time
                            , thumbnailPosition = position
                            , thumbnailCapturing = s.thumbnailCapturing || shouldCapture
                            , thumbnailSpriteClip = Nothing
                        }
                    , captureCmd
                    , Nothing
                    )

        ThumbnailHoverLeave ->
            ( State { s | seekHovering = False, thumbnailSpriteClip = Nothing }, Cmd.none, Nothing )



-- VIEW


{-| Render the player.

Returns the full player HTML. Wire this into your view with
`Html.map VideoMsg`. Also call `Video.subscriptions` in your app's
`subscriptions` function.

    view : Model -> Html Msg
    view model =
        Html.map VideoMsg (Video.view config model.videoState)

-}
view : Config -> State -> Html.Html Msg
view config (State s) =
    let
        aspectPaddingTopPct =
            case config.aspectRatio of
                Ratio16x9 ->
                    56.25

                Ratio4x3 ->
                    75.0

                Ratio21x9 ->
                    42.857

                CustomRatio ratio ->
                    1 / ratio * 100

        themeVars =
            case config.theme of
                Light ->
                    [ ( "--video-controls-bg", "rgba(0,0,0,0.7)" )
                    , ( "--video-controls-fg", "#ffffff" )
                    , ( "--video-progress-fill", "#ff0000" )
                    , ( "--video-progress-thumb", "#ffffff" )
                    , ( "--video-loaded-fill", "rgba(255,255,255,0.4)" )
                    , ( "--video-controls-bg-gradient", "rgba(0,0,0,0.75)" )
                    , ( "--video-error-bg", "rgba(0,0,0,0.85)" )
                    , ( "--video-error-fg", "#ffffff" )
                    , ( "--video-spinner-color", "rgba(255,255,255,0.8)" )
                    , ( "--video-live-bg", "#cc0000" )
                    , ( "--video-live-fg", "#ffffff" )
                    , ( "--video-cue-bg", "rgba(0,0,0," ++ String.fromFloat config.captionStyle.backgroundOpacity ++ ")" )
                    , ( "--video-cue-fg", "#ffffff" )
                    , ( "--video-thumb-bg", "rgba(0,0,0,0.85)" )
                    ]

                Dark ->
                    [ ( "--video-controls-bg", "rgba(255,255,255,0.15)" )
                    , ( "--video-controls-fg", "#1a1a1a" )
                    , ( "--video-progress-fill", "#0066ff" )
                    , ( "--video-progress-thumb", "#1a1a1a" )
                    , ( "--video-loaded-fill", "rgba(0,0,0,0.25)" )
                    , ( "--video-controls-bg-gradient", "rgba(255,255,255,0.2)" )
                    , ( "--video-error-bg", "rgba(255,255,255,0.9)" )
                    , ( "--video-error-fg", "#1a1a1a" )
                    , ( "--video-spinner-color", "rgba(0,0,0,0.6)" )
                    , ( "--video-live-bg", "#0044cc" )
                    , ( "--video-live-fg", "#ffffff" )
                    , ( "--video-cue-bg", "rgba(255,255,255," ++ String.fromFloat config.captionStyle.backgroundOpacity ++ ")" )
                    , ( "--video-cue-fg", "#1a1a1a" )
                    , ( "--video-thumb-bg", "rgba(255,255,255,0.9)" )
                    ]

                Custom vars ->
                    [ ( "--video-controls-bg", vars.controlsBg )
                    , ( "--video-controls-fg", vars.controlsFg )
                    , ( "--video-progress-fill", vars.progressFill )
                    , ( "--video-progress-thumb", vars.progressThumb )
                    , ( "--video-loaded-fill", vars.loadedFill )
                    , ( "--video-controls-bg-gradient", vars.controlsBgGradient )
                    , ( "--video-error-bg", vars.errorBg )
                    , ( "--video-error-fg", vars.errorFg )
                    , ( "--video-spinner-color", vars.spinnerColor )
                    , ( "--video-live-bg", vars.liveBg )
                    , ( "--video-live-fg", vars.liveFg )
                    , ( "--video-cue-bg", vars.cueBg )
                    , ( "--video-cue-fg", vars.cueFg )
                    , ( "--video-thumb-bg", vars.thumbBg )
                    ]

        keyboardAttrs =
            if config.keyboardShortcuts then
                [ Events.on "keydown"
                    (Decode.map KeyDown (Decode.field "key" Decode.string))
                ]
            else
                []

        touchAttrs =
            if config.enableTouchGestures then
                [ Events.on "touchstart" touchStartDecoder
                , Events.on "touchend" touchEndDecoder
                ]
            else
                []
    in
    Html.div
        ([ Css.inlineStyle
            ([ Css.position Css.Value.relative
             , Css.width (Css.Value.pct 100)
             , Css.overflow Css.Value.hidden
             , Css.backgroundColor (Css.Value.hex "#000000")
             , Css.property "outline" "2px solid transparent"
             , Css.property "outline-offset" "2px"
             ]
             ++ List.map (\( k, v ) -> Css.setVariable k v) themeVars
            )
         , Attr.id (Media.unwrapId config.mediaId ++ "-player")
         , Attr.attribute "tabindex" "0"
         , Attr.attribute "role" "region"
         , Attr.attribute "aria-label" "Video player"
         , Events.onMouseEnter ShowControls
         , Events.onMouseLeave HideControls
         , Events.on "mousemove" (Decode.map PlayerMouseMove (Decode.field "clientX" Decode.float))
         , Events.on "mouseup" (Decode.succeed SeekDragEnd)
         ] ++ keyboardAttrs ++ touchAttrs)
        [ -- Inject keyframe rule for the buffering spinner animation.
          Html.node "style" []
            [ Html.text
                ("@keyframes canopy-spin"
                    ++ "{ from { transform: rotate(0deg); }"
                    ++ "  to   { transform: rotate(360deg); } }"
                )
            ]
        , -- Aspect-ratio spacer
          Html.div
            [ Css.inlineStyle [ Css.paddingTop (Css.Value.pct aspectPaddingTopPct) ] ]
            []
        , -- Fill container: video + all overlays
          Html.div
            [ Css.inlineStyle
                [ Css.position Css.Value.absolute
                , Css.top Css.Value.zero
                , Css.left Css.Value.zero
                , Css.right Css.Value.zero
                , Css.bottom Css.Value.zero
                ]
            ]
            [ videoElement config s
            , Lazy.lazy Video.Caption.view
                { activeCues = s.activeCues
                , visible = s.activeCaptionTrack /= Nothing
                , fontSizeRem = captionFontSizeToRem config.captionStyle.fontSize
                }
            , Lazy.lazy bigPlayButton s
            , Lazy.lazy bufferingSpinner s
            , Lazy.lazy errorOverlay s
            , -- Accessibility live region
              Html.div
                [ Attr.attribute "aria-live" "polite"
                , Attr.attribute "aria-atomic" "true"
                , Css.inlineStyle
                    [ Css.position Css.Value.absolute
                    , Css.property "clip" "rect(0 0 0 0)"
                    , Css.width (Css.Value.px 1)
                    , Css.height (Css.Value.px 1)
                    , Css.overflow Css.Value.hidden
                    ]
                ]
                [ Html.text s.accessibilityAnnouncement ]
            , if s.mutedByAutoplayFallback then
                unmuteNotice
              else
                Html.text ""
            , if config.showControls then
                Lazy.lazy2 controlsBar config s
              else
                Html.text ""
            , if config.keyboardShortcuts && config.showKeyboardHelp && s.keyboardHelpVisible then
                keyboardHelpOverlay
              else
                Html.text ""
            ]
        ]


keyboardHelpOverlay : Html.Html Msg
keyboardHelpOverlay =
    let
        row key_ action =
            Html.tr []
                [ Html.td
                    [ Css.inlineStyle
                        [ Css.padding2 (Css.Value.px 3) (Css.Value.px 8)
                        , Css.fontFamily [ "monospace" ]
                        , Css.fontSize (Css.Value.rem 0.8125)
                        , Css.property "white-space" "nowrap"
                        , Css.textAlign Css.Value.right_
                        ]
                    ]
                    [ Html.text key_ ]
                , Html.td
                    [ Css.inlineStyle
                        [ Css.padding2 (Css.Value.px 3) (Css.Value.px 8)
                        , Css.fontSize (Css.Value.rem 0.8125)
                        ]
                    ]
                    [ Html.text action ]
                ]

        shortcuts =
            [ ( "Space / k", "Play / Pause" )
            , ( "← / j", "Rewind 10 s" )
            , ( "→ / l", "Forward 10 s" )
            , ( "↑", "Volume up" )
            , ( "↓", "Volume down" )
            , ( "m", "Mute / Unmute" )
            , ( "f", "Fullscreen" )
            , ( "p", "Picture-in-Picture" )
            , ( "c", "Toggle captions" )
            , ( ">", "Speed up" )
            , ( "<", "Speed down" )
            , ( "0–9", "Jump to 0%–90%" )
            , ( "Home", "Jump to start" )
            , ( "End", "Jump to end" )
            , ( "?", "This help" )
            ]
    in
    Html.div
        [ Css.inlineStyle
            [ Css.position Css.Value.absolute
            , Css.top Css.Value.zero
            , Css.left Css.Value.zero
            , Css.right Css.Value.zero
            , Css.bottom Css.Value.zero
            , Css.backgroundColor (Css.Value.rgba 0 0 0 0.85)
            , Css.property "color" "#ffffff"
            , Css.display Css.Value.flex_
            , Css.alignItems Css.Value.center
            , Css.justifyContent Css.Value.center
            , Css.zIndex (Css.Value.int_ 50)
            ]
        , Attr.attribute "role" "dialog"
        , Attr.attribute "aria-modal" "true"
        , Attr.attribute "aria-label" "Keyboard shortcuts"
        ]
        [ Html.div
            [ Css.inlineStyle
                [ Css.position Css.Value.relative
                , Css.backgroundColor (Css.Value.rgba 255 255 255 0.1)
                , Css.borderRadius (Css.Value.px 8)
                , Css.padding (Css.Value.px 24)
                , Css.minWidth (Css.Value.px 240)
                ]
            ]
            [ Html.button
                [ Css.inlineStyle
                    [ Css.position Css.Value.absolute
                    , Css.top (Css.Value.px 8)
                    , Css.right (Css.Value.px 8)
                    , Css.property "background" "none"
                    , Css.property "border" "none"
                    , Css.property "color" "inherit"
                    , Css.cursor Css.Value.pointer
                    , Css.fontSize (Css.Value.rem 1.25)
                    , Css.padding2 (Css.Value.px 2) (Css.Value.px 6)
                    ]
                , Attr.attribute "aria-label" "Close keyboard shortcuts"
                , Events.onClick ToggleKeyboardHelp
                ]
                [ Html.text "×" ]
            , Html.h2
                [ Css.inlineStyle
                    [ Css.fontSize (Css.Value.rem 0.9375)
                    , Css.property "font-weight" "600"
                    , Css.marginBottom (Css.Value.px 12)
                    , Css.property "margin-top" "0"
                    ]
                ]
                [ Html.text "Keyboard shortcuts" ]
            , Html.node "table"
                [ Css.inlineStyle
                    [ Css.property "border-collapse" "collapse"
                    , Css.width (Css.Value.pct 100)
                    ]
                ]
                [ Html.node "tbody" [] (List.map (\( k, a ) -> row k a) shortcuts) ]
            ]
        ]


videoElement : Config -> StateRecord -> Html.Html Msg
videoElement config s =
    let
        posterAttr =
            case config.poster of
                Just url ->
                    [ Attr.attribute "poster" url ]

                Nothing ->
                    []

        toSourceElement src =
            case src of
                Plain url maybeMime ->
                    Just
                        (Html.node "source"
                            (Attr.attribute "src" url
                                :: (maybeMime
                                        |> Maybe.map (\m -> [ Attr.attribute "type" m ])
                                        |> Maybe.withDefault []
                                   )
                            )
                            []
                        )

                _ ->
                    Nothing

        ( srcAttrs, sourceChildren ) =
            case ( config.source, List.isEmpty config.sources ) of
                ( Plain url maybeMime, True ) ->
                    -- Single plain source: use src= attribute (existing behaviour)
                    ( maybeMime
                        |> Maybe.map (\mime -> [ Attr.attribute "type" mime, Attr.attribute "src" url ])
                        |> Maybe.withDefault [ Attr.attribute "src" url ]
                    , []
                    )

                ( Plain _ _, False ) ->
                    -- Multi-source fallback chain: use <source> children only
                    ( []
                    , List.filterMap toSourceElement (config.source :: config.sources)
                    )

                _ ->
                    -- HLS / DASH: streaming library attaches the source, no src= needed
                    ( [], [] )

        externalTrackChildren =
            List.map
                (\t ->
                    Html.node "track"
                        ([ Attr.attribute "src" t.url
                         , Attr.attribute "label" t.label
                         , Attr.attribute "srclang" t.language
                         , Attr.attribute "kind" t.kind
                         ]
                            ++ (if t.default then [ Attr.attribute "default" "" ] else [])
                        )
                        []
                )
                config.externalCaptionTracks

        -- Extended state decoder: captures currentTime, duration, paused,
        -- muted, volume, playbackRate, readyState, ended, and error.
        -- `defaultState` is bound locally because Canopy's record-update
        -- syntax does not accept module-qualified names as the base.
        defaultState =
            Media.defaultState

        stateDecoder =
            Decode.map GotMediaState
                (Decode.map2
                    (\( ct, dur ) ( paused_, muted_ ) ->
                        ( ( ct, dur ), ( paused_, muted_ ) )
                    )
                    (Decode.map2 Tuple.pair
                        (Decode.at [ "target", "currentTime" ] Decode.float)
                        (Decode.at [ "target", "duration" ] Decode.float)
                    )
                    (Decode.map2 Tuple.pair
                        (Decode.at [ "target", "paused" ] Decode.bool)
                        (Decode.at [ "target", "muted" ] Decode.bool)
                    )
                    |> Decode.andThen
                        (\( ( ct, dur ), ( paused_, muted_ ) ) ->
                            Decode.map4
                                (\vol rate rs ended_ ->
                                    { defaultState
                                        | currentTime = ct
                                        , duration = dur
                                        , paused = paused_
                                        , muted = muted_
                                        , volume = vol
                                        , playbackRate = rate
                                        , readyState = readyStateFromInt rs
                                        , ended = ended_
                                    }
                                )
                                (Decode.at [ "target", "volume" ] Decode.float)
                                (Decode.at [ "target", "playbackRate" ] Decode.float)
                                (Decode.at [ "target", "readyState" ] Decode.int)
                                (Decode.at [ "target", "ended" ] Decode.bool)
                        )
                    |> Decode.andThen
                        (\mediaState ->
                            Decode.map
                                (\err -> { mediaState | error = err })
                                (Decode.at [ "target", "error" ]
                                    (Decode.nullable (Decode.map (\_ -> Media.NetworkError) (Decode.field "code" Decode.int)))
                                )
                        )
                )
    in
    Html.node "video"
        ([ Attr.id (Media.unwrapId config.mediaId)
         , Css.inlineStyle
            [ Css.width (Css.Value.pct 100)
            , Css.height (Css.Value.pct 100)
            , Css.display Css.Value.block
            ]
         , Attr.property "autoplay" (Json.Encode.bool config.autoplay)
         , Attr.property "muted" (Json.Encode.bool config.muted)
         , Attr.property "loop" (Json.Encode.bool config.loop)
         , Attr.attribute "preload" (Media.preloadToString config.preload)
         , Media.Video.onFullscreenChange SyncFullscreenState
         , Events.on "timeupdate" stateDecoder
         , Events.on "loadedmetadata" stateDecoder
         , Events.on "play" stateDecoder
         , Events.on "pause" stateDecoder
         , Events.on "ended" stateDecoder
         , Events.on "volumechange" stateDecoder
         , Events.on "ratechange" stateDecoder
         , Events.on "progress" (Decode.succeed FetchBuffered)
         , Events.on "waiting" stateDecoder
         ] ++ posterAttr ++ srcAttrs)
        (sourceChildren ++ externalTrackChildren)


bigPlayButton : StateRecord -> Html.Html Msg
bigPlayButton s =
    if not s.mediaState.paused || s.hasError then
        Html.text ""
    else
        Html.button
            [ Css.inlineStyle
                [ Css.position Css.Value.absolute
                , Css.top (Css.Value.pct 50)
                , Css.left (Css.Value.pct 50)
                , Css.transform
                    [ Css.Value.translate (Css.Value.pct -50) (Css.Value.pct -50) ]
                , Css.width (Css.Value.px 72)
                , Css.height (Css.Value.px 72)
                , Css.borderRadius (Css.Value.pct 50)
                , Css.backgroundColor (Css.Value.rgba 0 0 0 0.6)
                , Css.property "border" "none"
                , Css.color (Css.Value.hex "#ffffff")
                , Css.cursor Css.Value.pointer
                , Css.display Css.Value.flex_
                , Css.alignItems Css.Value.center
                , Css.justifyContent Css.Value.center
                , Css.zIndex (Css.Value.int_ 10)
                , Css.pointerEvents Css.Value.auto
                ]
            , Attr.attribute "aria-label" "Play"
            , Events.onClick PlayPause
            ]
            [ Html.node "svg"
                [ Attr.attribute "viewBox" "0 0 24 24"
                , Attr.attribute "width" "36"
                , Attr.attribute "height" "36"
                , Attr.attribute "fill" "currentColor"
                , Attr.attribute "aria-hidden" "true"
                ]
                [ Html.node "path"
                    [ Attr.attribute "d" "M8 5v14l11-7z" ]
                    []
                ]
            ]


bufferingSpinner : StateRecord -> Html.Html Msg
bufferingSpinner s =
    let
        isBuffering =
            not s.mediaState.paused
                && (s.mediaState.readyState == Media.HaveFutureData
                        || s.mediaState.readyState == Media.HaveCurrentData
                   )
    in
    Html.div
        [ Css.inlineStyle
            [ Css.position Css.Value.absolute
            , Css.top (Css.Value.pct 50)
            , Css.left (Css.Value.pct 50)
            , Css.transform
                [ Css.Value.translate (Css.Value.pct -50) (Css.Value.pct -50) ]
            , Css.width (Css.Value.px 48)
            , Css.height (Css.Value.px 48)
            , Css.display (if isBuffering then Css.Value.block else Css.Value.none)
            , Css.pointerEvents Css.Value.none
            , Css.zIndex (Css.Value.int_ 10)
            ]
        ]
        [ Html.node "svg"
            [ Attr.attribute "viewBox" "0 0 48 48"
            , Attr.attribute "width" "48"
            , Attr.attribute "height" "48"
            , Css.inlineStyle
                [ Css.property "animation" "canopy-spin 1s linear infinite" ]
            ]
            [ Html.node "circle"
                [ Attr.attribute "cx" "24"
                , Attr.attribute "cy" "24"
                , Attr.attribute "r" "20"
                , Attr.attribute "fill" "none"
                , Attr.attribute "stroke" "var(--video-spinner-color, rgba(255,255,255,0.8))"
                , Attr.attribute "stroke-width" "4"
                , Attr.attribute "stroke-dasharray" "80"
                , Attr.attribute "stroke-dashoffset" "20"
                ]
                []
            ]
        ]


errorOverlay : StateRecord -> Html.Html Msg
errorOverlay s =
    if not s.hasError then
        Html.text ""
    else
        let
            errorText =
                case s.customErrorMsg of
                    Just msg_ ->
                        msg_

                    Nothing ->
                        s.lastError
                            |> Maybe.map Media.errorToString
                            |> Maybe.withDefault "An unknown error occurred"

            retryExhausted =
                s.retryCount >= 3
        in
        Html.div
            [ Css.inlineStyle
                [ Css.position Css.Value.absolute
                , Css.top Css.Value.zero
                , Css.left Css.Value.zero
                , Css.right Css.Value.zero
                , Css.bottom Css.Value.zero
                , Css.display Css.Value.flex_
                , Css.flexDirection Css.Value.column
                , Css.alignItems Css.Value.center
                , Css.justifyContent Css.Value.center
                , Css.property "background-color" "var(--video-error-bg, rgba(0,0,0,0.85))"
                , Css.property "color" "var(--video-error-fg, #ffffff)"
                , Css.zIndex (Css.Value.int_ 50)
                ]
            ]
            [ Html.node "svg"
                [ Attr.attribute "viewBox" "0 0 24 24"
                , Attr.attribute "width" "48"
                , Attr.attribute "height" "48"
                , Attr.attribute "fill" "none"
                , Attr.attribute "stroke" "#ff4444"
                , Attr.attribute "stroke-width" "2"
                , Css.inlineStyle [ Css.marginBottom (Css.Value.px 12) ]
                ]
                [ Html.node "circle"
                    [ Attr.attribute "cx" "12"
                    , Attr.attribute "cy" "12"
                    , Attr.attribute "r" "10"
                    ]
                    []
                , Html.node "line"
                    [ Attr.attribute "x1" "12"
                    , Attr.attribute "y1" "8"
                    , Attr.attribute "x2" "12"
                    , Attr.attribute "y2" "12"
                    ]
                    []
                , Html.node "line"
                    [ Attr.attribute "x1" "12"
                    , Attr.attribute "y1" "16"
                    , Attr.attribute "x2" "12.01"
                    , Attr.attribute "y2" "16"
                    ]
                    []
                ]
            , Html.p
                [ Css.inlineStyle
                    [ Css.fontSize (Css.Value.rem 0.9375)
                    , Css.textAlign Css.Value.center
                    , Css.padding2 Css.Value.zero (Css.Value.px 24)
                    , Css.margin Css.Value.zero
                    , Css.marginBottom (Css.Value.px 16)
                    ]
                ]
                [ Html.text (if retryExhausted then "Playback failed" else errorText) ]
            , if retryExhausted then
                Html.text ""
              else
                Html.button
                    [ Css.inlineStyle
                        [ Css.padding2 (Css.Value.px 8) (Css.Value.px 20)
                        , Css.backgroundColor (Css.Value.rgba 255 255 255 0.15)
                        , Css.property "border" "1px solid rgba(255,255,255,0.3)"
                        , Css.borderRadius (Css.Value.px 4)
                        , Css.property "color" "var(--video-error-fg, #ffffff)"
                        , Css.cursor Css.Value.pointer
                        , Css.fontSize (Css.Value.rem 0.875)
                        ]
                    , Attr.attribute "aria-label" "Retry playback"
                    , Events.onClick Retry
                    ]
                    [ Html.text "Retry" ]
            ]


unmuteNotice : Html.Html Msg
unmuteNotice =
    Html.button
        [ Css.inlineStyle
            [ Css.position Css.Value.absolute
            , Css.top (Css.Value.px 8)
            , Css.right (Css.Value.px 8)
            , Css.zIndex (Css.Value.int_ 25)
            , Css.property "background-color" "rgba(0,0,0,0.7)"
            , Css.property "color" "#ffffff"
            , Css.property "border" "1px solid rgba(255,255,255,0.4)"
            , Css.borderRadius (Css.Value.px 4)
            , Css.padding2 (Css.Value.px 6) (Css.Value.px 12)
            , Css.fontSize (Css.Value.rem 0.875)
            , Css.cursor Css.Value.pointer
            ]
        , Attr.attribute "aria-label" "Unmute"
        , Events.onClick DismissAutoplayNotice
        ]
        [ Html.text "Tap to unmute" ]


controlsBar : Config -> StateRecord -> Html.Html Msg
controlsBar config s =
    let
        currentChapterTitle =
            activeChapterAt s.mediaState.currentTime s.chapters
                |> Maybe.map .title
                |> Maybe.withDefault ""
    in
    Html.div
        [ Css.inlineStyle
            [ Css.position Css.Value.absolute
            , Css.bottom Css.Value.zero
            , Css.left Css.Value.zero
            , Css.right Css.Value.zero
            , Css.property "background"
                "linear-gradient(to top, var(--video-controls-bg-gradient, rgba(0,0,0,0.75)), transparent)"
            , Css.property "color" "var(--video-controls-fg, #ffffff)"
            , Css.opacity (Css.Value.num (if s.controlsVisible then 1.0 else 0.0))
            , Css.pointerEvents
                (if s.controlsVisible then Css.Value.auto else Css.Value.none)
            , Css.transition "opacity" (Css.Value.ms 200) Css.Value.easeOut (Css.Value.ms 0)
            , Css.padding4 (Css.Value.px 32) (Css.Value.px 8) (Css.Value.px 8) (Css.Value.px 8)
            , Css.zIndex (Css.Value.int_ 30)
            ]
        ]
        [ -- Thumbnail preview
          Video.Thumbnail.view
            { time = s.thumbnailTime
            , position = s.thumbnailPosition
            , visible = s.seekHovering
            , thumbnailDataUrl = s.thumbnailDataUrl
            , spriteClip = s.thumbnailSpriteClip
            }
        , -- Chapter title badge
          if currentChapterTitle /= "" then
            chapterTitleBadge currentChapterTitle
          else
            Html.text ""
        , -- Live badge + seek bar row
          Html.div
            [ Css.inlineStyle
                [ Css.display Css.Value.flex_
                , Css.alignItems Css.Value.center
                , Css.width (Css.Value.pct 100)
                , Css.marginBottom (Css.Value.px 4)
                ]
            ]
            [ if s.isLive then liveBadge else Html.text ""
            , if not s.isLive then
                Video.Controls.seekBar
                    { onSeek = SeekTo
                    , onThumbnailHover =
                        Just (\t p -> ThumbnailMsg (ThumbnailHoverAt t p))
                    , onThumbnailLeave = Just (ThumbnailMsg ThumbnailHoverLeave)
                    , onSeekDragStart = SeekDragStart
                    , onSeekDragEnd = SeekDragEnd
                    , onSeekTouchDragStart = SeekTouchDragStart
                    , onSeekTouchDragMove = SeekTouchDragMove
                    , onNoOp = ControlsActivity
                    , currentTime = s.mediaState.currentTime
                    , duration = s.mediaState.duration
                    , buffered =
                        List.map
                            (\r -> { start = r.start, end = r.end })
                            s.mediaState.buffered
                    , showThumbnail = True
                    , chapters = List.map (\c -> { startTime = c.startTime, endTime = c.endTime, title = c.title }) s.chapters
                    }
              else
                Html.text ""
            ]
        , -- Button row
          Html.div
            [ Css.inlineStyle
                [ Css.display Css.Value.flex_
                , Css.alignItems Css.Value.center
                , Css.gap (Css.Value.px 4)
                ]
            ]
            [ Video.Controls.playPauseButton
                { onPlayPause = PlayPause
                , paused = s.mediaState.paused
                }
            , Video.Controls.volumeControl
                { onSetVolume = SetVolume
                , onToggleMute = ToggleMute
                , volume = s.mediaState.volume
                , muted = s.mediaState.muted
                }
            , if not s.isLive then
                Video.Controls.timeDisplay
                    { currentTime = s.mediaState.currentTime
                    , duration = s.mediaState.duration
                    }
              else
                Html.text ""
            , -- Flex spacer
              Html.div [ Css.inlineStyle [ Css.property "flex" "1" ] ] []
            , if not (List.isEmpty s.availableQualities) && not s.isCompact then
                Video.Controls.qualityMenu
                    { onSelect = SetQuality
                    , onOpen = OpenMenu QualityMenu
                    , onClose = CloseMenu
                    , isOpen = s.activeMenu == Just QualityMenu
                    , levels =
                        List.map
                            (\q ->
                                { index = q.index
                                , label = q.label
                                , bitrate = q.bitrate
                                }
                            )
                            s.availableQualities
                    , currentLevel = s.currentQualityIndex
                    }
              else
                Html.text ""
            , if not s.isCompact then
                Video.Controls.speedMenu
                    { onSelect = SetPlaybackRate
                    , onOpen = OpenMenu SpeedMenu
                    , onClose = CloseMenu
                    , isOpen = s.activeMenu == Just SpeedMenu
                    , currentRate = s.mediaState.playbackRate
                    }
              else
                Html.text ""
            , if not (List.isEmpty s.captionTracks) then
                Video.Controls.captionsMenu
                    { onSelect = SetCaptionTrack
                    , onOpen = OpenMenu CaptionsMenu
                    , onClose = CloseMenu
                    , isOpen = s.activeMenu == Just CaptionsMenu
                    , tracks = s.captionTracks
                    , activeTrack = s.activeCaptionTrack
                    }
              else
                Html.text ""
            , if not s.isCompact then
                Video.Controls.pipButton
                    { onToggle = TogglePip
                    , isPip = s.isPip
                    }
              else
                Html.text ""
            , Video.Controls.remoteButton
                { onToggle = ToggleRemotePlayback
                , remoteAvailable = s.remoteAvailable
                }
            , if not s.fullscreenUnavailable then
                Video.Controls.fullscreenButton
                    { onToggle = ToggleFullscreen
                    , isFullscreen = s.isFullscreen
                    }
              else
                Html.text ""
            , if config.keyboardShortcuts && config.showKeyboardHelp then
                Html.button
                    [ Css.inlineStyle
                        [ Css.width (Css.Value.px 40)
                        , Css.height (Css.Value.px 40)
                        , Css.property "background" "none"
                        , Css.property "border" "none"
                        , Css.color Css.Value.inherit_
                        , Css.cursor Css.Value.pointer
                        , Css.fontSize (Css.Value.rem 0.875)
                        , Css.padding Css.Value.zero
                        , Css.borderRadius (Css.Value.px 4)
                        ]
                    , Attr.attribute "aria-label" "Keyboard shortcuts"
                    , Attr.attribute "aria-expanded"
                        (if s.keyboardHelpVisible then "true" else "false")
                    , Events.onClick ToggleKeyboardHelp
                    ]
                    [ Html.text "?" ]
              else
                Html.text ""
            ]
        ]


chapterTitleBadge : String -> Html.Html msg
chapterTitleBadge title =
    Html.div
        [ Css.inlineStyle
            [ Css.position Css.Value.absolute
            , Css.bottom (Css.Value.px 56)
            , Css.left (Css.Value.px 8)
            , Css.property "background-color" "rgba(0,0,0,0.6)"
            , Css.property "color" "#ffffff"
            , Css.fontSize (Css.Value.rem 0.8125)
            , Css.padding2 (Css.Value.px 2) (Css.Value.px 8)
            , Css.borderRadius (Css.Value.px 2)
            , Css.pointerEvents Css.Value.none
            ]
        ]
        [ Html.text title ]


liveBadge : Html.Html msg
liveBadge =
    Html.div
        [ Css.inlineStyle
            [ Css.property "background-color" "var(--video-live-bg, #cc0000)"
            , Css.property "color" "var(--video-live-fg, #ffffff)"
            , Css.fontSize (Css.Value.rem 0.6875)
            , Css.fontFamily [ "monospace" ]
            , Css.property "font-weight" "bold"
            , Css.padding2 (Css.Value.px 2) (Css.Value.px 6)
            , Css.borderRadius (Css.Value.px 2)
            , Css.marginRight (Css.Value.px 8)
            , Css.property "letter-spacing" "0.05em"
            ]
        ]
        [ Html.text "LIVE" ]



-- HELPERS


readyStateFromInt : Int -> Media.ReadyState
readyStateFromInt n =
    case n of
        0 ->
            Media.HaveNothing

        1 ->
            Media.HaveMetadata

        2 ->
            Media.HaveCurrentData

        3 ->
            Media.HaveFutureData

        _ ->
            Media.HaveEnoughData


hlsLevelToQuality : Hls.Level -> QualityLevel
hlsLevelToQuality level =
    { index = level.index
    , label = level.name
    , bitrate = level.bitrate
    , width = level.width
    , height = level.height
    }


dashReprToQuality : Dash.Representation -> QualityLevel
dashReprToQuality repr =
    { index = repr.index
    , label =
        if repr.height > 0 then
            String.fromInt repr.height ++ "p"
        else
            String.fromInt (repr.bitrate // 1000) ++ "k"
    , bitrate = repr.bitrate
    , width = repr.width
    , height = repr.height
    }


convertTrackInfos : List Media.Track.TrackInfo -> List Video.Caption.Track
convertTrackInfos infos =
    List.indexedMap
        (\i info ->
            { index = i
            , label = info.label
            , language = info.language
            , kind = Media.Track.trackKindToString info.kind
            }
        )
        infos


cueToChapter : Media.Track.Cue -> ChapterCue
cueToChapter cue =
    { startTime = cue.startTime
    , endTime = cue.endTime
    , title = cue.text
    }


activeChapterAt : Float -> List ChapterCue -> Maybe ChapterCue
activeChapterAt t chaptersList =
    List.filter (\c -> c.startTime <= t && t < c.endTime) chaptersList
        |> List.head


findSpriteAt : Float -> List ThumbnailSprite -> Maybe ThumbnailSprite
findSpriteAt t sprites =
    List.filter (\sp -> sp.startTime <= t && t < sp.endTime) sprites
        |> List.head


touchStartDecoder : Decode.Decoder Msg
touchStartDecoder =
    Decode.map2 TouchStart
        (Decode.at [ "changedTouches", "0", "clientX" ] Decode.float)
        (Decode.at [ "changedTouches", "0", "clientY" ] Decode.float)


touchEndDecoder : Decode.Decoder Msg
touchEndDecoder =
    Decode.map3 TouchEnd
        (Decode.at [ "changedTouches", "0", "clientX" ] Decode.float)
        (Decode.at [ "changedTouches", "0", "clientY" ] Decode.float)
        (Decode.field "timeStamp" Decode.float)


{-| Parse a WebVTT sprite sheet into a list of ThumbnailSprite records.

Each non-header cue block should have an image URL with an `#xywh=x,y,w,h`
fragment identifying the sprite region.

Handles all three line ending conventions (`\r\n`, `\r`, `\n`).

-}
parseSpriteVtt : String -> List ThumbnailSprite
parseSpriteVtt content =
    content
        |> String.replace "\r\n" "\n"
        |> String.replace "\r" "\n"
        |> String.split "\n\n"
        |> List.filterMap parseSpriteBlock


parseSpriteBlock : String -> Maybe ThumbnailSprite
parseSpriteBlock block =
    let
        nonEmpty =
            block
                |> String.split "\n"
                |> List.map String.trim
                |> List.filter (not << String.isEmpty)
                |> List.filter (\l -> l /= "WEBVTT")

        timeLineMaybe =
            List.filter (String.contains "-->") nonEmpty |> List.head

        imageLineMaybe =
            List.filter (not << String.contains "-->") nonEmpty |> List.head
    in
    Maybe.andThen
        (\timeLine ->
            Maybe.andThen
                (parseSpriteTimesAndImage timeLine)
                imageLineMaybe
        )
        timeLineMaybe


parseSpriteTimesAndImage : String -> String -> Maybe ThumbnailSprite
parseSpriteTimesAndImage timeLine imageLine =
    let
        timeParts =
            String.split " --> " timeLine

        startMaybe =
            List.head timeParts |> Maybe.andThen parseVttTime

        endMaybe =
            List.drop 1 timeParts |> List.head |> Maybe.andThen parseVttTime
    in
    Maybe.andThen
        (\start ->
            Maybe.andThen
                (\end -> parseSpriteImage start end imageLine)
                endMaybe
        )
        startMaybe


parseSpriteImage : Float -> Float -> String -> Maybe ThumbnailSprite
parseSpriteImage startTime endTime imageLine =
    case String.split "#xywh=" imageLine of
        [ url, xywhStr ] ->
            case List.filterMap String.toInt (String.split "," xywhStr) of
                [ x, y, w, h ] ->
                    Just
                        { startTime = startTime
                        , endTime = endTime
                        , url = url
                        , x = x
                        , y = y
                        , w = w
                        , h = h
                        }

                _ ->
                    Nothing

        _ ->
            Nothing


{-| Parse a VTT time string (HH:MM:SS.mmm or MM:SS.mmm) into seconds.

Returns `Nothing` for malformed input. Note that `Just 0.0` is a valid
result for the timestamp `"00:00:00.000"`, so callers can reliably
distinguish a successful parse of zero from a parse failure.

-}
parseVttTime : String -> Maybe Float
parseVttTime timeStr =
    let
        msPart =
            String.split "." timeStr
                |> List.drop 1
                |> List.head
                |> Maybe.andThen String.toFloat
                |> Maybe.withDefault 0
                |> (\v -> v / 1000)

        withoutMs =
            String.split "." timeStr
                |> List.head
                |> Maybe.withDefault timeStr

        timeParts =
            String.split ":" withoutMs
                |> List.filterMap String.toInt
    in
    case timeParts of
        [ h, m, sec ] ->
            Just (toFloat (h * 3600 + m * 60 + sec) + msPart)

        [ m, sec ] ->
            Just (toFloat (m * 60 + sec) + msPart)

        _ ->
            Nothing


formatAnnounceTime : Float -> String
formatAnnounceTime seconds =
    let
        totalSecs =
            floor (max 0 seconds)

        h =
            totalSecs // 3600

        m =
            (totalSecs - h * 3600) // 60

        sec =
            totalSecs - h * 3600 - m * 60

        pad n =
            if n < 10 then
                "0" ++ String.fromInt n
            else
                String.fromInt n
    in
    if h > 0 then
        String.fromInt h ++ ":" ++ pad m ++ ":" ++ pad sec
    else
        pad m ++ ":" ++ pad sec


captionFontSizeToRem : Video.Config.CaptionFontSize -> Float
captionFontSizeToRem fs =
    case fs of
        Video.Config.CaptionSmall ->
            0.75

        Video.Config.CaptionMedium ->
            1.0

        Video.Config.CaptionLarge ->
            1.4



-- ACCESSORS


{-| Get the current playback time in seconds. -}
currentTime : State -> Float
currentTime (State s) =
    s.mediaState.currentTime


{-| Get the total duration of the video in seconds.

Returns 0 before metadata is loaded, and infinity for live streams.

-}
duration : State -> Float
duration (State s) =
    s.mediaState.duration


{-| Whether playback is currently paused. -}
paused : State -> Bool
paused (State s) =
    s.mediaState.paused


{-| The list of buffered time ranges. -}
buffered : State -> List Media.TimeRange
buffered (State s) =
    s.mediaState.buffered


{-| The currently selected quality level, or Nothing when using auto ABR
or when no levels have been loaded yet. -}
currentQuality : State -> Maybe QualityLevel
currentQuality (State s) =
    if s.currentQualityIndex == -1 then
        Nothing
    else
        List.filter (\q -> q.index == s.currentQualityIndex) s.availableQualities
            |> List.head


{-| All quality levels available for manual selection. -}
availableQualities : State -> List QualityLevel
availableQualities (State s) =
    s.availableQualities


{-| All caption/subtitle tracks available on the media element. -}
captionTracks : State -> List Video.Caption.Track
captionTracks (State s) =
    s.captionTracks


{-| Whether the controls bar is currently visible. -}
controlsVisible : State -> Bool
controlsVisible (State s) =
    s.controlsVisible


{-| The last playback error, if any. -}
lastError : State -> Maybe Media.Error
lastError (State s) =
    s.lastError


{-| Whether remote playback (Chromecast / AirPlay) is available on this device. -}
remoteAvailable : State -> Bool
remoteAvailable (State s) =
    s.remoteAvailable


{-| Whether a playback error is currently displayed. -}
hasError : State -> Bool
hasError (State s) =
    s.hasError


{-| Whether the current source is a live stream. -}
isLive : State -> Bool
isLive (State s) =
    s.isLive


{-| Whether the player is currently in fullscreen mode. -}
isFullscreen : State -> Bool
isFullscreen (State s) =
    s.isFullscreen


{-| Whether the player is currently in Picture-in-Picture mode. -}
isPip : State -> Bool
isPip (State s) =
    s.isPip


{-| Whether the player is in compact mode (container width < 480 px). -}
isCompact : State -> Bool
isCompact (State s) =
    s.isCompact


{-| The currently open dropdown menu, or Nothing when all menus are closed. -}
activeMenu : State -> Maybe ActiveMenu
activeMenu (State s) =
    s.activeMenu


{-| The data URL of the most recently captured thumbnail frame, or Nothing
while a capture is pending or no hover is active. -}
thumbnailDataUrl : State -> Maybe String
thumbnailDataUrl (State s) =
    s.thumbnailDataUrl


{-| Whether a thumbnail frame capture is currently in-flight. -}
thumbnailCapturing : State -> Bool
thumbnailCapturing (State s) =
    s.thumbnailCapturing


{-| Current playback speed as a multiplier (e.g. 1.0 normal, 2.0 double). -}
playbackRate : State -> Float
playbackRate (State s) =
    s.mediaState.playbackRate


{-| Current volume level, 0.0-1.0, regardless of mute state. -}
volume : State -> Float
volume (State s) =
    s.mediaState.volume


{-| Whether audio is currently muted. -}
muted : State -> Bool
muted (State s) =
    s.mediaState.muted


{-| The index of the currently active caption track, or Nothing when captions are off. -}
activeCaptionTrack : State -> Maybe Int
activeCaptionTrack (State s) =
    s.activeCaptionTrack


{-| All chapter cues extracted from the chapters text track. -}
chapters : State -> List ChapterCue
chapters (State s) =
    s.chapters


{-| All parsed thumbnail sprites from the VTT sprite sheet. -}
thumbnailSprites : State -> List ThumbnailSprite
thumbnailSprites (State s) =
    s.thumbnailSprites


{-| Seconds of video buffered ahead of the current playback position.

Computed from the buffered time ranges without any additional JS calls.
Returns `0.0` if no buffered range contains the current playhead position.

-}
bufferAhead : State -> Float
bufferAhead (State s) =
    let
        ct =
            s.mediaState.currentTime
    in
    s.mediaState.buffered
        |> List.filter (\r -> r.start <= ct && ct < r.end)
        |> List.head
        |> Maybe.map (\r -> r.end - ct)
        |> Maybe.withDefault 0.0


{-| Total seconds across all buffered time ranges.

Useful as a rough measure of total network-cached content. Returns `0.0`
when nothing is buffered.

-}
totalBuffered : State -> Float
totalBuffered (State s) =
    List.foldl (\r acc -> acc + (r.end - r.start)) 0.0 s.mediaState.buffered


{-| Whether the keyboard shortcut help overlay is currently visible. -}
keyboardHelpVisible : State -> Bool
keyboardHelpVisible (State s) =
    s.keyboardHelpVisible


{-| Whether fullscreen mode is unavailable in the current browser context.

Becomes `True` after a fullscreen request was sent but the fullscreen
state did not transition to active — for example in iframes without the
`allowfullscreen` attribute. When `True` the fullscreen button is hidden.

-}
fullscreenUnavailable : State -> Bool
fullscreenUnavailable (State s) =
    s.fullscreenUnavailable
