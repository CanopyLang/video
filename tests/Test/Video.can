                let
                    ( _, _, outMsg ) =
                        run (Video.DashMsg Video.DashStreamInitialized)
                in
                Expect.equal (Just Video.Ready) outMsg

        , test "DashError sets hasError to True" <|
            \_ ->
                let
                    ( state, _, _ ) =
                        run (Video.DashMsg (Video.DashError "manifest parse failed"))
                in
                Expect.equal True (Video.hasError state)

        , test "DashError emits PlaybackError OutMsg" <|
            \_ ->
                let
                    ( _, _, outMsg ) =
                        run (Video.DashMsg (Video.DashError "manifest parse failed"))
                in
                case outMsg of
                    Just (Video.PlaybackError _) ->
                        Expect.pass

                    _ ->
                        Expect.fail "Expected PlaybackError"
        ]



-- PLAYBACK HANDLER TESTS


playbackHandlerTests : Test
playbackHandlerTests =
    let
        cfg =
            Video.Config.defaultConfig
                (Media.id "playback-handler")
                (Video.Source.plain "https://example.com/v.mp4")

        initState =
            Tuple.first (Video.init cfg)

        run msg =
            Video.update cfg msg initState
    in
    describe "Playback handler"
        [ test "Retry clears hasError flag" <|
            \_ ->
                let
                    ( state, _, _ ) = run Video.Retry
                in
                Expect.equal False (Video.hasError state)

        , test "Retry clears lastError" <|
            \_ ->
                let
                    ( state, _, _ ) = run Video.Retry
                in
                Expect.equal Nothing (Video.lastError state)

        , test "PlayPause issues a Cmd (not a no-op)" <|
            \_ ->
                let
                    ( _, cmd, _ ) = run Video.PlayPause
                in
                Expect.notEqual Cmd.none cmd

        , test "SeekTo issues a Cmd" <|
            \_ ->
                let
                    ( _, cmd, _ ) = run (Video.SeekTo 30.0)
                in
                Expect.notEqual Cmd.none cmd

        , test "SetVolume issues a Cmd" <|
            \_ ->
                let
                    ( _, cmd, _ ) = run (Video.SetVolume 0.5)
                in
                Expect.notEqual Cmd.none cmd

        , test "ToggleMute issues a Cmd" <|
            \_ ->
                let
                    ( _, cmd, _ ) = run Video.ToggleMute
                in
                Expect.notEqual Cmd.none cmd

        , test "SetPlaybackRate 2.0 closes active menu and issues Cmd" <|
            \_ ->
                let
                    ( opened, _, _ ) = run (Video.OpenMenu Video.SpeedMenu)
                    ( state, cmd, _ ) =
                        Video.update cfg (Video.SetPlaybackRate 2.0) opened
                in
                Expect.all
                    [ \_ -> Expect.equal Nothing (Video.activeMenu state)
                    , \_ -> Expect.notEqual Cmd.none cmd
                    ]
                    ()

        , test "GotThumbnailFrame Ok sets thumbnailDataUrl and clears capturing flag" <|
            \_ ->
                let
                    url = "data:image/png;base64,abc"
                    ( state, _, _ ) =
                        run (Video.GotThumbnailFrame (Ok url))
                in
                Expect.all
                    [ \_ -> Expect.equal (Just url) (Video.thumbnailDataUrl state)
                    , \_ -> Expect.equal False (Video.thumbnailCapturing state)
                    ]
                    ()

        , test "GotThumbnailFrame Err clears thumbnailDataUrl and capturing flag" <|
            \_ ->
                let
                    ( state, _, _ ) =
                        run (Video.GotThumbnailFrame (Err Media.NetworkError))
                in
                Expect.all
                    [ \_ -> Expect.equal Nothing (Video.thumbnailDataUrl state)
                    , \_ -> Expect.equal False (Video.thumbnailCapturing state)
                    ]
                    ()
        ]



