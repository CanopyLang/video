                    qualities =
                        [ { index = 0, label = "720p", bitrate = 2000000, width = 1280, height = 720 }
                        , { index = 1, label = "1080p", bitrate = 5000000, width = 1920, height = 1080 }
                        ]

                    ( state, _, _ ) =
                        run (Video.DashMsg (Video.DashQualitiesLoaded qualities))
                in
                Expect.equal 2 (List.length (Video.availableQualities state))

        , test "DashQualitiesLoaded with levels emits QualityLevelsLoaded OutMsg" <|
            \_ ->
                let
                    qualities =
                        [ { index = 0, label = "720p", bitrate = 2000000, width = 1280, height = 720 } ]

                    ( _, _, outMsg ) =
                        run (Video.DashMsg (Video.DashQualitiesLoaded qualities))
                in
                case outMsg of
                    Just (Video.QualityLevelsLoaded qs) ->
                        Expect.equal 1 (List.length qs)

                    _ ->
                        Expect.fail "Expected QualityLevelsLoaded"

        , test "DashQualitiesLoaded empty list emits no OutMsg" <|
            \_ ->
                let
                    ( _, _, outMsg ) =
                        run (Video.DashMsg (Video.DashQualitiesLoaded []))
                in
                Expect.equal Nothing outMsg

        , test "DashStreamInitialized emits Ready OutMsg" <|
