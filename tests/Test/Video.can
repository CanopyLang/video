-- KEYBOARD SHORTCUTS


keyboardShortcutTests : Test
keyboardShortcutTests =
    let
        cfg =
            Video.Config.defaultConfig
                (Media.id "kb-test")
                (Video.Source.plain "https://example.com/v.mp4")

        ( initState, _ ) = Video.init cfg

        run key =
            Video.update cfg (Video.KeyDown key) initState
    in
    describe "keyboard shortcuts"
        [ test "Space issues a play/pause cmd" <|
            \_ ->
                let ( _, cmd, _ ) = run " "
                in Expect.notEqual Cmd.none cmd

        , test "k issues a play/pause cmd" <|
            \_ ->
                let ( _, cmd, _ ) = run "k"
                in Expect.notEqual Cmd.none cmd

        , test "ArrowLeft issues a seek cmd" <|
            \_ ->
                let ( _, cmd, _ ) = run "ArrowLeft"
                in Expect.notEqual Cmd.none cmd

        , test "ArrowRight issues a seek cmd" <|
            \_ ->
                let ( _, cmd, _ ) = run "ArrowRight"
                in Expect.notEqual Cmd.none cmd

        , test "ArrowUp issues a volume cmd" <|
            \_ ->
                let ( _, cmd, _ ) = run "ArrowUp"
                in Expect.notEqual Cmd.none cmd

        , test "ArrowDown issues a volume cmd" <|
            \_ ->
                let ( _, cmd, _ ) = run "ArrowDown"
                in Expect.notEqual Cmd.none cmd

        , test "m issues a mute cmd" <|
            \_ ->
                let ( _, cmd, _ ) = run "m"
                in Expect.notEqual Cmd.none cmd

        , test "f issues a fullscreen cmd" <|
            \_ ->
                let ( _, cmd, _ ) = run "f"
                in Expect.notEqual Cmd.none cmd

        , test "Escape closes any open menu" <|
            \_ ->
                let
                    ( withMenu, _, _ ) = Video.update cfg (Video.OpenMenu Video.QualityMenu) initState
                    ( state, _, _ ) = Video.update cfg (Video.KeyDown "Escape") withMenu
                in
                Expect.equal Nothing (Video.activeMenu state)

        , test "Home issues a seek-to-0 cmd" <|
            \_ ->
                let ( _, cmd, _ ) = run "Home"
                in Expect.notEqual Cmd.none cmd

        , test "End issues a seek-to-end cmd" <|
            \_ ->
                let ( _, cmd, _ ) = run "End"
                in Expect.notEqual Cmd.none cmd

        , test "< decreases playback speed" <|
            \_ ->
                let ( _, cmd, _ ) = run "<"
                in Expect.notEqual Cmd.none cmd

        , test "> increases playback speed" <|
            \_ ->
                let ( _, cmd, _ ) = run ">"
                in Expect.notEqual Cmd.none cmd

        , test "0 issues a seek cmd (0%)" <|
            \_ ->
                let ( _, cmd, _ ) = run "0"
                in Expect.notEqual Cmd.none cmd

        , test "9 issues a seek cmd (90%)" <|
            \_ ->
                let ( _, cmd, _ ) = run "9"
                in Expect.notEqual Cmd.none cmd

        , test "unknown key is a no-op" <|
            \_ ->
                let ( _, cmd, _ ) = run "q"
                in Expect.equal Cmd.none cmd
        ]



-- TOUCH GESTURES


touchGestureTests : Test
touchGestureTests =
    let
        cfg =
            Video.Config.defaultConfig
                (Media.id "touch-test")
                (Video.Source.plain "https://example.com/v.mp4")

        ( initState, _ ) = Video.init cfg

        withTouchStart x y =
            Video.update cfg (Video.TouchStart x y) initState
                |> (\( s, _, _ ) -> s)

        runEnd startX startY endX endY =
            let stateAfterStart = withTouchStart startX startY
            in Video.update cfg (Video.TouchEnd endX endY 100.0) stateAfterStart
    in
    describe "touch gestures"
        [ test "tap (small dx/dy) issues a play/pause cmd" <|
            \_ ->
                let ( _, cmd, _ ) = runEnd 100 100 102 101
                in Expect.notEqual Cmd.none cmd

        , test "swipe left (dx < -20) issues a seek-back cmd" <|
            \_ ->
                let ( _, cmd, _ ) = runEnd 100 100 60 100
                in Expect.notEqual Cmd.none cmd

        , test "swipe right (dx > 20) issues a seek-forward cmd" <|
            \_ ->
                let ( _, cmd, _ ) = runEnd 100 100 140 100
                in Expect.notEqual Cmd.none cmd

        , test "swipe up (dy < -20) issues a volume-up cmd" <|
            \_ ->
                let ( _, cmd, _ ) = runEnd 100 100 100 60
                in Expect.notEqual Cmd.none cmd

        , test "swipe down (dy > 20) issues a volume-down cmd" <|
            \_ ->
                let ( _, cmd, _ ) = runEnd 100 100 100 140
                in Expect.notEqual Cmd.none cmd

        , test "ambiguous movement is a no-op" <|
            \_ ->
                let ( _, cmd, _ ) = runEnd 100 100 110 110
                in Expect.equal Cmd.none cmd
        ]



-- GOT MEDIA STATE ANALYTICS


gotMediaStateAnalyticsTests : Test
gotMediaStateAnalyticsTests =
    let
        cfg =
            Video.Config.defaultConfig
                (Media.id "analytics-test")
                (Video.Source.plain "https://example.com/v.mp4")

        ( initState, _ ) = Video.init cfg

        baseMediaState =
            Media.defaultState

        makeMediaState ct dur rs ended_ =
            { baseMediaState
                | currentTime = ct
                , duration = dur
                , readyState = rs
                , ended = ended_
                , paused = False
            }

        run ms =
            Video.update cfg (Video.GotMediaState ms) initState
    in
    describe "GotMediaState analytics"
        [ test "first HaveEnoughData emits FirstFrameReady" <|
            \_ ->
                let
                    ms = makeMediaState 1.0 100.0 Media.HaveEnoughData False
                    ( _, _, outMsg ) = run ms
                in
                Expect.equal (Just Video.FirstFrameReady) outMsg

        , test "ended=True emits Ended" <|
            \_ ->
                let
                    ms = makeMediaState 100.0 100.0 Media.HaveEnoughData True
                    -- First trigger firstFrame so it's emitted, then trigger ended
                    ( state1, _, _ ) = run (makeMediaState 1.0 100.0 Media.HaveEnoughData False)
                    ( _, _, outMsg ) = Video.update cfg (Video.GotMediaState ms) state1
                in
                Expect.equal (Just Video.Ended) outMsg

        , test "buffering start emits Rebuffering" <|
            \_ ->
                let
                    -- First ensure firstFrame was emitted
                    ( state1, _, _ ) = run (makeMediaState 1.0 100.0 Media.HaveEnoughData False)
                    -- Now trigger buffering (not paused, low readyState)
                    ms = makeMediaState 5.0 100.0 Media.HaveCurrentData False
                    ( _, _, outMsg ) = Video.update cfg (Video.GotMediaState ms) state1
                in
                Expect.equal (Just Video.Rebuffering) outMsg

        , test "progress at 25% emits PlaybackProgress 0.25" <|
            \_ ->
                let
                    ( state1, _, _ ) = run (makeMediaState 1.0 100.0 Media.HaveEnoughData False)
                    ms = makeMediaState 25.0 100.0 Media.HaveEnoughData False
                    ( _, _, outMsg ) = Video.update cfg (Video.GotMediaState ms) state1
                in
                case outMsg of
                    Just (Video.PlaybackProgress p) ->
                        Expect.within (Expect.Absolute 0.01) 0.25 p

                    _ ->
                        Expect.fail "Expected PlaybackProgress 0.25"

        , test "same milestone not re-emitted" <|
            \_ ->
                let
                    ( state1, _, _ ) = run (makeMediaState 1.0 100.0 Media.HaveEnoughData False)
                    ms25 = makeMediaState 25.0 100.0 Media.HaveEnoughData False
                    ( state25, _, _ ) = Video.update cfg (Video.GotMediaState ms25) state1
                    ms25b = makeMediaState 26.0 100.0 Media.HaveEnoughData False
                    ( _, _, outMsg ) = Video.update cfg (Video.GotMediaState ms25b) state25
                in
                Expect.equal Nothing outMsg
        ]



-- VTT PARSING


vttParsingTests : Test
vttParsingTests =
    describe "VTT time parsing"
        [ test "HH:MM:SS.mmm -> seconds" <|
            \_ ->
                Expect.within (Expect.Absolute 0.001) 90.5 (Video.parseVttTime "00:01:30.500")

        , test "MM:SS.mmm -> seconds" <|
            \_ ->
                Expect.within (Expect.Absolute 0.001) 90.5 (Video.parseVttTime "01:30.500")

        , test "zero time" <|
            \_ ->
                Expect.within (Expect.Absolute 0.001) 0.0 (Video.parseVttTime "00:00:00.000")

        , test "empty string returns 0" <|
            \_ ->
                Expect.within (Expect.Absolute 0.001) 0.0 (Video.parseVttTime "")
        ]



-- CAPTION PARSER


captionParserTests : Test
captionParserTests =
    describe "VTT inline markup parsing"
        [ test "plain text produces text node" <|
            \_ ->
                let nodes = Video.Caption.parseVttText "hello"
                in Expect.equal 1 (List.length nodes)

        , test "b tag produces nodes" <|
            \_ ->
                let nodes = Video.Caption.parseVttText "<b>bold</b>"
                in Expect.notEqual 0 (List.length nodes)

        , test "voice tag produces a node" <|
            \_ ->
                let nodes = Video.Caption.parseVttText "<v Alice>hello</v>"
                in Expect.notEqual 0 (List.length nodes)

        , test "unclosed tag does not crash" <|
            \_ ->
                let nodes = Video.Caption.parseVttText "<b no close"
                in Expect.notEqual 0 (List.length nodes)

        , test "empty string produces empty list" <|
            \_ ->
                let nodes = Video.Caption.parseVttText ""
                in Expect.equal 0 (List.length nodes)
        ]
